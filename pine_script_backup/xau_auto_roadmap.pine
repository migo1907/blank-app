//@version=6
// =============================================================================
//  XAU INTRADAY AUTO SCENARIO ROADMAP   (self-leveling, plain-language plan)
//  -------------------------------------------------------------------------
//  Read ONLY the big colored box in the panel:
//    GRAY  = WAIT (do nothing)
//    OLIVE / DARK RED = GET READY (do not enter yet)
//    GREEN = BUY NOW  (use the Entry / Stop / Take profit shown)
//    RED   = SELL NOW (use the Entry / Stop / Take profit shown)
//  A matching BUY/SELL arrow prints on the chart at the same moment.
//
//  Levels are computed automatically from prior-period pivots + ATR, with an
//  optional higher-timeframe swing as the far target. Nothing to type.
//  WORKS ON ANY TIMEFRAME (1m..Daily): with "Auto-adjust all timeframes" ON
//  (default), the pivot source, trend gate and HTF magnet are picked from the
//  chart automatically. 5m/15m for scalps, 30m/1h intraday, 4h/D for swings.
// =============================================================================
indicator("XAU Auto Scenario Roadmap", shorttitle="XAU Auto Roadmap", overlay=true, max_lines_count=200, max_labels_count=300, max_boxes_count=20)

// ---------- INPUTS: Auto-level engine ----------
grpA = "Auto Levels"
i_pivTF    = input.timeframe("D",   "Pivot source timeframe", group=grpA)
i_zoneMult = input.float(0.5,       "Zone width (x ATR)", group=grpA, minval=0.1, step=0.1)
i_useHTF   = input.bool(true,       "Use HTF swing as far-target magnet", group=grpA)
i_structTF = input.timeframe("240", "HTF swing timeframe", group=grpA)
i_atrLen   = input.int(14,          "ATR length", group=grpA)

// ---------- INPUTS: Engine ----------
grpE = "Engine"
i_htf    = input.timeframe("60", "Trend gate timeframe", group=grpE)
i_emaFast= input.int(50,  "Trend EMA fast", group=grpE)
i_emaSlow= input.int(200, "Trend EMA slow", group=grpE)
i_pivLen = input.int(5,   "Swing length (CHoCH)", group=grpE)
i_swLook = input.int(12,  "Sweep recency window (bars)", group=grpE)
i_stopBuf= input.float(8.0, "Stop buffer (points)", group=grpE)
i_tol    = input.float(6.0, "Zone tolerance (points)", group=grpE)

// ---------- INPUTS: Display ----------
grpD = "Display"
i_proj     = input.int(4, "Bars per projection leg", group=grpD, minval=1)
i_showBull = input.bool(true, "Show BULL scenario path", group=grpD)
i_showBear = input.bool(true, "Show BEAR scenario path", group=grpD)
i_panelPos = input.string("Top Right", "Panel position", options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=grpD)

// ---------- AUTO TIMEFRAME RESOLUTION ----------
// When ON, the pivot source, trend gate and HTF magnet are all picked from the
// chart timeframe, so the indicator works on 1m..Daily with nothing to change.
i_autoTF = input.bool(true, "Auto-adjust all timeframes to chart", group=grpA, tooltip="ON = pivot source, trend gate and HTF magnet are derived from the chart automatically. OFF = use the manual values above.")

f_autoPiv() =>
    s = timeframe.in_seconds()
    s <= 3600 ? "D" : s <= 14400 ? "W" : "M"
f_autoGate() =>
    s = timeframe.in_seconds()
    s <= 60 ? "15" : s <= 180 ? "30" : s <= 300 ? "60" : s <= 1800 ? "240" : s <= 3600 ? "D" : s <= 14400 ? "W" : "M"
f_autoStruct() =>
    s = timeframe.in_seconds()
    s <= 300 ? "240" : s <= 1800 ? "D" : s <= 14400 ? "W" : "M"

pivTF    = i_autoTF ? f_autoPiv()    : i_pivTF
htfTF    = i_autoTF ? f_autoGate()   : i_htf
structTF = i_autoTF ? f_autoStruct() : i_structTF

// ============================ AUTO LEVEL ENGINE ============================
prevH = request.security(syminfo.tickerid, pivTF, high[1], lookahead=barmerge.lookahead_on)
prevL = request.security(syminfo.tickerid, pivTF, low[1],  lookahead=barmerge.lookahead_on)
prevC = request.security(syminfo.tickerid, pivTF, close[1],lookahead=barmerge.lookahead_on)

PP = (prevH + prevL + prevC) / 3.0
R1 = 2.0 * PP - prevL
S1 = 2.0 * PP - prevH
R2 = PP + (prevH - prevL)
S2 = PP - (prevH - prevL)
R3 = prevH + 2.0 * (PP - prevL)
S3 = prevL - 2.0 * (prevH - PP)

atr = ta.atr(i_atrLen)
w   = atr * i_zoneMult

levels   = array.from(S3, S2, S1, PP, R1, R2, R3)
resAbove = array.new<float>()
supBelow = array.new<float>()
for i = 0 to array.size(levels) - 1
    v = array.get(levels, i)
    if v > close
        array.push(resAbove, v)
    else
        array.push(supBelow, v)
nRes = array.size(resAbove)
nSup = array.size(supBelow)

nearRes = nRes > 0 ? array.get(resAbove, 0) : close + atr * 2.0
res2    = nRes > 1 ? array.get(resAbove, 1) : nearRes + atr * 2.0
res3    = nRes > 2 ? array.get(resAbove, 2) : res2 + atr * 2.0
nearSup = nSup > 0 ? array.get(supBelow, nSup - 1) : close - atr * 2.0
sup2    = nSup > 1 ? array.get(supBelow, nSup - 2) : nearSup - atr * 2.0
sup3    = nSup > 2 ? array.get(supBelow, nSup - 3) : sup2 - atr * 2.0

// HTF swing magnet (extracted to functions = no repaint warning)
f_htfPivH() => ta.pivothigh(5, 5)
f_htfPivL() => ta.pivotlow(5, 5)
htfPH = request.security(syminfo.tickerid, structTF, f_htfPivH(), lookahead=barmerge.lookahead_off)
htfPL = request.security(syminfo.tickerid, structTF, f_htfPivL(), lookahead=barmerge.lookahead_off)
var float lastHTFHigh = na
var float lastHTFLow  = na
if not na(htfPH)
    lastHTFHigh := htfPH
if not na(htfPL)
    lastHTFLow := htfPL

buyHi  = nearSup + w
buyLo  = nearSup - w
sellLo = nearRes - w
sellHi = nearRes + w
t1 = nearRes
t2 = res2
t3 = res3
d1 = nearSup
d2 = sup2
d3 = sup3
if i_useHTF and not na(lastHTFHigh) and lastHTFHigh > t2
    t3 := lastHTFHigh
if i_useHTF and not na(lastHTFLow) and lastHTFLow < d2
    d3 := lastHTFLow

// ============================ TREND + STRUCTURE ============================
f_htfDir() =>
    ef = ta.ema(close, i_emaFast)
    es = ta.ema(close, i_emaSlow)
    ef > es ? 1 : -1
htfDir  = request.security(syminfo.tickerid, htfTF, f_htfDir())
htfBull = htfDir > 0

ph = ta.pivothigh(i_pivLen, i_pivLen)
pl = ta.pivotlow(i_pivLen, i_pivLen)
var float lastSwingHigh = na
var float lastSwingLow  = na
if not na(ph)
    lastSwingHigh := ph
if not na(pl)
    lastSwingLow := pl
chochUp = not na(lastSwingHigh) and close > lastSwingHigh and close[1] <= lastSwingHigh

var bool  sweepArmed = false
var float sweepLevel = na
var int   sweepBar   = na
if low < buyLo
    sweepArmed := true
    sweepLevel := buyLo
    sweepBar   := bar_index
else if low < buyHi
    sweepArmed := true
    sweepLevel := buyHi
    sweepBar   := bar_index
if sweepArmed and not na(sweepBar) and (bar_index - sweepBar) > i_swLook
    sweepArmed := false
    sweepLevel := na
sweepReclaim = sweepArmed and not na(sweepLevel) and close > sweepLevel and close > open
if sweepReclaim
    sweepArmed := false
var int lastReclaimBar = na
if sweepReclaim
    lastReclaimBar := bar_index
reclaimRecent = not na(lastReclaimBar) and (bar_index - lastReclaimBar) <= i_swLook

atSupply     = high >= sellLo - i_tol and close <= sellHi
supplyReject = atSupply and close < open and (high - close) > (close - low)
brokeFloor   = close < buyHi and close[1] >= buyHi
rawLong  = chochUp and reclaimRecent
rawShort = supplyReject or brokeFloor

// Fire only when not already in an active window (stops the arrow spam),
// and FREEZE entry/stop/targets at the instant of firing so the panel
// never drifts away from the price the signal was actually given at.
var int   actState = 0
var int   actBars  = 0
var float entryF = na
var float stopF  = na
var float tp1F   = na
var float tp2F   = na
var float tp3F   = na

newLong  = rawLong  and actBars == 0
newShort = rawShort and actBars == 0 and not rawLong

if newLong
    actState := 3
    actBars  := 3
    entryF := close
    stopF  := math.min(buyLo, low) - i_stopBuf
    tp1F   := t1
    tp2F   := t2
    tp3F   := t3
else if newShort
    actState := 4
    actBars  := 3
    entryF := close
    stopF  := math.max(sellHi, high) + i_stopBuf
    tp1F   := d1
    tp2F   := d2
    tp3F   := d3
else if actBars > 0
    actBars -= 1
    if actBars == 0
        actState := 0

plotshape(newLong,  title="BUY",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime,0), size=size.small, text="BUY")
plotshape(newShort, title="SELL", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,0),  size=size.small, text="SELL")
alertcondition(newLong,  "XAU BUY trigger",  "XAU bounce long triggered")
alertcondition(newShort, "XAU SELL trigger", "XAU short triggered")

// ============================ CALCULATIONS =================================
longEntry = buyHi
longStop  = buyLo - i_stopBuf
riskL     = math.max(longEntry - longStop, 1.0)
sellEntry = sellHi
f_pts(float a, float b) => str.tostring(math.round(math.abs(a - b)))
f_rr(float tgt)         => str.tostring((tgt - longEntry) / riskL, "#.#") + "R"

// ============================ ZONES + TARGET LINES =========================
var box buyBox  = na
var box sellBox = na
if barstate.islast
    box.delete(buyBox)
    box.delete(sellBox)
    buyBox  := box.new(bar_index-250, buyHi,  bar_index+i_proj*6, buyLo,  xloc=xloc.bar_index, border_color=color.new(color.green,40), bgcolor=color.new(color.green,88))
    sellBox := box.new(bar_index-250, sellHi, bar_index+i_proj*6, sellLo, xloc=xloc.bar_index, border_color=color.new(color.red,40),   bgcolor=color.new(color.red,88))

plot(t1, "T1", color=color.new(color.aqua,40),    style=plot.style_circles, linewidth=1)
plot(t2, "T2", color=color.new(color.aqua,60),    style=plot.style_circles, linewidth=1)
plot(t3, "T3", color=color.new(color.orange,40),  style=plot.style_circles, linewidth=1)
plot(d2, "D2", color=color.new(color.fuchsia,50), style=plot.style_circles, linewidth=1)
plot(d3, "D3", color=color.new(color.fuchsia,60), style=plot.style_circles, linewidth=1)

// ============================ SCENARIO PATHS ===============================
var array<line>  segs = array.new<line>()
var array<label> lbls = array.new<label>()
f_seg(array<line> arr, int x1, float y1, int x2, float y2, color c) =>
    array.push(arr, line.new(x1, y1, x2, y2, xloc=xloc.bar_index, color=c, width=2, style=line.style_dashed))
f_lbl(array<label> arr, int x, float y, string t, color tc) =>
    array.push(arr, label.new(x, y, t, xloc=xloc.bar_index, style=label.style_label_left, color=color.new(color.black,100), textcolor=tc, size=size.small))

if barstate.islast
    if array.size(segs) > 0
        for ln in segs
            line.delete(ln)
        array.clear(segs)
    if array.size(lbls) > 0
        for lb in lbls
            label.delete(lb)
        array.clear(lbls)

    x = bar_index
    p = i_proj
    cG = color.new(color.lime, 0)
    cR = color.new(color.red, 0)

    if i_showBull
        swMid = (buyHi + buyLo) / 2.0
        f_seg(segs, x,     close,     x+p,   swMid,     cG)
        f_seg(segs, x+p,   swMid,     x+2*p, longEntry, cG)
        f_seg(segs, x+2*p, longEntry, x+3*p, t1,        cG)
        f_seg(segs, x+3*p, t1,        x+4*p, t2,        cG)
        f_seg(segs, x+4*p, t2,        x+5*p, t3,        cG)
        f_lbl(lbls, x+p,   swMid,     "SWEEP "+str.tostring(buyHi,"#.#")+"/"+str.tostring(buyLo,"#.#"), cG)
        f_lbl(lbls, x+2*p, longEntry, "BUY "+str.tostring(longEntry,"#.#")+"  stop "+str.tostring(longStop,"#.#"), cG)
        f_lbl(lbls, x+3*p, t1, "T1 "+str.tostring(t1,"#.#")+"  +"+f_pts(t1,longEntry)+" ("+f_rr(t1)+")", color.aqua)
        f_lbl(lbls, x+4*p, t2, "T2 "+str.tostring(t2,"#.#")+"  +"+f_pts(t2,longEntry)+" ("+f_rr(t2)+")", color.aqua)
        f_lbl(lbls, x+5*p, t3, "T3 "+str.tostring(t3,"#.#")+"  +"+f_pts(t3,longEntry)+" ("+f_rr(t3)+")", color.orange)

    if i_showBear
        f_seg(segs, x,     close,    x+p,   sellHi, cR)
        f_seg(segs, x+p,   sellHi,   x+2*p, d1,     cR)
        f_seg(segs, x+2*p, d1,       x+3*p, d2,     cR)
        f_seg(segs, x+3*p, d2,       x+4*p, d3,     cR)
        f_lbl(lbls, x+p,   sellHi, "SELL "+str.tostring(sellHi,"#.#")+" (reject) / break <"+str.tostring(buyHi,"#.#"), cR)
        f_lbl(lbls, x+2*p, d1, "D1 "+str.tostring(d1,"#.#")+"  -"+f_pts(sellHi,d1), color.fuchsia)
        f_lbl(lbls, x+3*p, d2, "D2 "+str.tostring(d2,"#.#")+"  -"+f_pts(sellHi,d2), color.fuchsia)
        f_lbl(lbls, x+4*p, d3, "D3 "+str.tostring(d3,"#.#")+"  -"+f_pts(sellHi,d3), color.fuchsia)

// ============================ ACTION PANEL =================================
i_panelSize = input.string("Small", "Panel text size", options=["Tiny","Small","Normal"], group=grpD)
pSize = i_panelSize == "Tiny" ? size.tiny : i_panelSize == "Normal" ? size.normal : size.small
hSize = i_panelSize == "Tiny" ? size.small : i_panelSize == "Normal" ? size.large : size.normal

f_tfLabel(string tf) =>
    switch tf
        "15"  => "15m"
        "30"  => "30m"
        "60"  => "1h"
        "240" => "4h"
        "D"   => "D"
        "W"   => "W"
        "M"   => "M"
        => tf

f_pos() =>
    switch i_panelPos
        "Top Right"    => position.top_right
        "Top Left"     => position.top_left
        "Bottom Right" => position.bottom_right
        => position.bottom_left
var table panel = table.new(f_pos(), 2, 7, border_width=1)

if barstate.islast
    biasTxt  = htfBull ? "UP" : "DOWN"
    head     = "WAIT"
    hbg      = color.new(color.gray, 30)
    noteTxt  = "No trigger yet. Numbers below are the PLAN only - do not enter."
    // Default (WAIT): show the bias-aligned scenario so the panel always
    // mirrors the levels already drawn on the chart. "~" = estimate, not live.
    planEntry = htfBull ? longEntry : sellEntry
    planStop  = htfBull ? longStop  : sellHi + i_stopBuf
    planT1    = htfBull ? t1 : d1
    planT2    = htfBull ? t2 : d2
    planT3    = htfBull ? t3 : d3
    entryTxt = "~"+str.tostring(planEntry,"#.#")
    stopTxt  = "~"+str.tostring(planStop,"#.#")
    tpTxt    = "~"+str.tostring(planT1,"#.#")+" / "+str.tostring(planT2,"#.#")+" / "+str.tostring(planT3,"#.#")
    if actState == 3
        head     := "BUY NOW"
        hbg      := color.new(color.green, 0)
        entryTxt := str.tostring(entryF, "#.#")
        stopTxt  := str.tostring(stopF, "#.#")
        tpTxt    := str.tostring(tp1F,"#.#")+" / "+str.tostring(tp2F,"#.#")+" / "+str.tostring(tp3F,"#.#")
        noteTxt  := "Buy now. Set the stop. Bank profit at the targets."
    else if actState == 4
        head     := "SELL NOW"
        hbg      := color.new(color.red, 0)
        entryTxt := str.tostring(entryF, "#.#")
        stopTxt  := str.tostring(stopF, "#.#")
        tpTxt    := str.tostring(tp1F,"#.#")+" / "+str.tostring(tp2F,"#.#")+" / "+str.tostring(tp3F,"#.#")
        noteTxt  := "Sell now. Set the stop. Bank profit at the targets."
    else if reclaimRecent
        head     := "GET READY (BUY)"
        hbg      := color.new(color.olive, 0)
        entryTxt := "~"+str.tostring(longEntry,"#.#")
        stopTxt  := "~"+str.tostring(longStop,"#.#")
        tpTxt    := "~"+str.tostring(t1,"#.#")+" / "+str.tostring(t2,"#.#")+" / "+str.tostring(t3,"#.#")
        noteTxt  := "BUY setup forming. Do NOT enter until it says BUY NOW."
    else if atSupply
        head     := "GET READY (SELL)"
        hbg      := color.new(color.maroon, 0)
        entryTxt := "~"+str.tostring(sellEntry,"#.#")
        stopTxt  := "~"+str.tostring(sellHi + i_stopBuf,"#.#")
        tpTxt    := "~"+str.tostring(d1,"#.#")+" / "+str.tostring(d2,"#.#")+" / "+str.tostring(d3,"#.#")
        noteTxt  := "SELL setup forming. Do NOT enter until it says SELL NOW."

    tfMode = i_autoTF ? "Auto TF" : "Manual TF"
    tfStr  = f_tfLabel(pivTF) + " / " + f_tfLabel(htfTF) + " / " + f_tfLabel(structTF)

    table.cell(panel, 0, 0, "XAU PLAN", text_color=color.white, bgcolor=color.new(color.black,0), text_size=pSize)
    table.cell(panel, 1, 0, "Bias "+biasTxt, text_color = htfBull?color.lime:color.red, bgcolor=color.new(color.black,0), text_size=pSize)
    table.cell(panel, 0, 1, head, text_color=color.white, bgcolor=hbg, text_size=hSize)
    table.cell(panel, 1, 1, "",   text_color=color.white, bgcolor=hbg, text_size=hSize)
    table.cell(panel, 0, 2, "Entry", text_color=color.white, text_size=pSize)
    table.cell(panel, 1, 2, entryTxt, text_color=color.aqua, text_size=pSize)
    table.cell(panel, 0, 3, "Stop loss", text_color=color.white, text_size=pSize)
    table.cell(panel, 1, 3, stopTxt, text_color=color.red, text_size=pSize)
    table.cell(panel, 0, 4, "Take profit", text_color=color.white, text_size=pSize)
    table.cell(panel, 1, 4, tpTxt, text_color=color.lime, text_size=pSize)
    table.cell(panel, 0, 5, "What to do", text_color=color.white, text_size=pSize)
    table.cell(panel, 1, 5, noteTxt, text_color=color.yellow, text_size=pSize)
    table.cell(panel, 0, 6, tfMode+" P/G/M", text_color=color.gray, text_size=pSize)
    table.cell(panel, 1, 6, tfStr, text_color=color.silver, text_size=pSize)
