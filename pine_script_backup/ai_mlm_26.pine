//@version=6
indicator("AI MLM 26", overlay=true, max_labels_count=500, max_bars_back=510, max_lines_count=200)

// ═══════════════════════════════════════════════════════════════════
// AI MLM 26 — Read-Only ML Signal Quality Mirror
// Shows Lorentzian KNN signal quality, entry/TP/SL historically,
// and a live dashboard table. NO alerts, NO webhook, NO heartbeat.
// Updated as ML training progresses.
// ═══════════════════════════════════════════════════════════════════

// ── Timeframe auto-detection ─────────────────────────────────────
int   tfMins = math.max(1, timeframe.in_seconds() / 60)
bool  isTF2  = tfMins <= 2
bool  isTF5  = tfMins <= 5  and not isTF2
bool  isTF15 = tfMins <= 15 and not isTF2 and not isTF5
bool  isTF30 = tfMins <= 30 and not isTF2 and not isTF5 and not isTF15
bool  isTF4H = tfMins >= 240
bool  isTF1H = tfMins >= 60 and not isTF4H

// ═══════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════
bool  autoTF      = input.bool(true,  "⚡ Auto-Adjust for Timeframe",    group="⚙️ Settings")
int   mlK         = input.int(8,      "K Neighbors",                     group="⚙️ Settings", minval=3, maxval=20)
int   mlDepth_inp = input.int(300,    "History Depth",                   group="⚙️ Settings", minval=100, maxval=500)
int   mlLag       = input.int(4,      "Forward Lag",                     group="⚙️ Settings", minval=1, maxval=20)
float mlMinScore  = input.float(0.55, "Min Score (signal threshold)",    group="⚙️ Settings", minval=0.50, maxval=0.90, step=0.05)
float learnRate   = input.float(0.05, "Adaptive Learn Rate",             group="⚙️ Settings", minval=0.01, maxval=0.30, step=0.01)
float winReward   = input.float(0.15, "Win Weight Reward",               group="⚙️ Settings", minval=0.05, maxval=0.50, step=0.05)
float lossPenalty = input.float(0.20, "Loss Weight Penalty",             group="⚙️ Settings", minval=0.05, maxval=0.50, step=0.05)
float tp1_inp     = input.float(1.5,  "TP1 ATR Multiplier",              group="⚙️ Settings")
float tp2_inp     = input.float(2.5,  "TP2 ATR Multiplier",              group="⚙️ Settings")
float tp3_inp     = input.float(4.0,  "TP3 ATR Multiplier",              group="⚙️ Settings")
float sl_inp      = input.float(1.5,  "SL ATR Multiplier",               group="⚙️ Settings")
bool  showLines   = input.bool(true,  "Show TP/SL lines on last signal", group="🎨 Display")
bool  showLabels  = input.bool(true,  "Show BUY/SELL signal labels",     group="🎨 Display")
bool  showDash    = input.bool(true,  "Show Dashboard Table",            group="🎨 Display")
bool  useSMC      = input.bool(true,  "Enable SMC Features (F9-F14)",    group="🧠 Features")
bool  useSession  = input.bool(true,  "Enable Session KZ (F15)",         group="🧠 Features")
bool  useMTF      = input.bool(true,  "Enable MTF Alignment (F16)",      group="🧠 Features")
bool  useDXY      = input.bool(true,  "Enable DXY Inverse (F17)",        group="🧠 Features")
bool  useVolDelta = input.bool(true,  "Enable Volume Delta (F18)",        group="🧠 Features")
bool  useRSIDiv   = input.bool(true,  "Enable RSI Divergence (F19)",      group="🧠 Features")
bool  useFib      = input.bool(true,  "Enable Fibonacci Zone (F20)",      group="🧠 Features")
bool  useVWAP     = input.bool(true,  "Enable VWAP Distance (F21)",       group="🧠 Features")
bool  useNewFeats = input.bool(true,  "Enable F22-F26",                   group="🧠 Features")
bool  useKernel   = input.bool(true,  "Kernel Regression Filter",         group="🧠 Features")
int   kWin_inp    = input.int(8,      "Kernel Window",                    group="🧠 Features", minval=3, maxval=50)
float kH          = input.float(8.0,  "Kernel Bandwidth h",               group="🧠 Features", minval=1.0, maxval=50.0)
float kAlpha      = input.float(1.0,  "Kernel Alpha",                     group="🧠 Features", minval=0.1, maxval=5.0)
int   adxLen      = input.int(14,     "ADX Length",                       group="🔎 Filters")
float adxThr      = input.float(20.0, "ADX Sideways Threshold",           group="🔎 Filters")
float atrRR       = input.float(0.75, "ATR Range Ratio",                  group="🔎 Filters")
float emaBandPct  = input.float(0.3,  "EMA Band %",                       group="🔎 Filters")

// ── Auto-TF overrides ─────────────────────────────────────────────
int   mlDepth    = autoTF ? (isTF2 ? 150 : isTF5 ? 250 : isTF15 ? 350 : isTF30 ? 400 : 500) : mlDepth_inp
int   kWin       = autoTF ? (isTF2 ? 5   : isTF5 ? 8   : isTF15 ? 12  : isTF30 ? 14  : isTF1H ? 16 : 20) : kWin_inp
float atrMultTP1 = autoTF ? (isTF2 ? 1.0 : isTF5 ? 1.5 : isTF15 ? 2.0 : isTF30 ? 2.2 : isTF1H ? 2.5 : 3.0) : tp1_inp
float atrMultTP2 = autoTF ? (isTF2 ? 1.8 : isTF5 ? 2.5 : isTF15 ? 3.5 : isTF30 ? 3.8 : isTF1H ? 4.5 : 5.5) : tp2_inp
float atrMultTP3 = autoTF ? (isTF2 ? 3.0 : isTF5 ? 4.0 : isTF15 ? 5.5 : isTF30 ? 6.0 : isTF1H ? 7.0 : 9.0) : tp3_inp
float atrMultSL  = autoTF ? (isTF2 ? 0.8 : isTF5 ? 1.5 : isTF15 ? 2.0 : isTF30 ? 2.2 : isTF1H ? 2.5 : 3.0) : sl_inp

// ═══════════════════════════════════════════════════════════════════
// BASE INDICATORS
// ═══════════════════════════════════════════════════════════════════
float rsiVal   = ta.rsi(close, 14)
float maLong   = ta.ema(close, 200)
float maShort  = ta.ema(close, 50)
float atr      = ta.atr(14)
float atrSma   = ta.sma(atr, 20)
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
float macdLine = ta.ema(close, 12) - ta.ema(close, 26)
float macdHist = macdLine - ta.ema(macdLine, 9)
[bbUp, bbMid, bbLow_] = ta.bb(close, 20, 2.0)
float bbPct    = (close - bbLow_) / math.max(bbUp - bbLow_, 0.0001)
float willR    = ta.wpr(14)
float cmo      = ta.cmo(close, 14) / 100.0
float stochK   = ta.stoch(close, high, low, 14)
float stochD   = ta.sma(stochK, 3)

// MTF + DXY
[ma50_1h, ma200_1h, rsi_1h] = request.security(syminfo.tickerid, "60", [ta.ema(close, 50), ta.ema(close, 200), ta.rsi(close, 14)])
float ma50_4h  = request.security(syminfo.tickerid, "240", ta.ema(close, 50))
[dxyEma5, dxyEma20] = request.security("DXY", timeframe.period, [ta.ema(close, 5), ta.ema(close, 20)])

// Regime
bool adxFlat      = adxVal < adxThr
bool atrCompressed = atr < atrSma * atrRR
bool emaTooClose  = math.abs(maShort - maLong) / maLong * 100.0 < emaBandPct
bool isSideways   = (adxFlat ? 1 : 0) + (atrCompressed ? 1 : 0) + (emaTooClose ? 1 : 0) >= 2
string mainTrend  = close > ma50_1h and rsi_1h > 50 ? "UPTREND" : close < ma50_1h and rsi_1h < 50 ? "DOWNTREND" : "SIDEWAYS"

// Swing structure
float swingHigh20   = ta.highest(high, 20)
float swingLow20    = ta.lowest(low,  20)
float highest10High = ta.highest(high, 10)
float lowest10Low   = ta.lowest(low,  10)
float highest50     = ta.highest(high, 50)
float lowest50      = ta.lowest(low,  50)
float highest100    = ta.highest(high, 100)
float lowest100     = ta.lowest(low,  100)
float rsiHigh14     = ta.highest(rsiVal, 14)
float rsiLow14      = ta.lowest(rsiVal,  14)
float highestHigh14 = ta.highest(high, 14)
float lowestLow14   = ta.lowest(low,  14)

// ═══════════════════════════════════════════════════════════════════
// F1–F26 (identical to production)
// ═══════════════════════════════════════════════════════════════════
float f1  = (rsiVal - 50.0) / 50.0
float f2  = math.min(adxVal / 50.0, 1.0) * (diPlus > diMinus ? 1.0 : -1.0)
float f3  = math.max(-1.0, math.min(1.0, (atr / atrSma - 1.0) * 2.0))
float f4  = math.max(-1.0, math.min(1.0, (bbPct - 0.5) * 2.0))
float f5  = math.max(-1.0, math.min(1.0, macdHist / math.max(atr * 0.1, 0.0001)))
float f6  = -(willR + 50.0) / 50.0
float f7  = cmo
float f8  = math.max(-1.0, math.min(1.0, (close - maLong) / (atr * 5.0)))

float f9_raw  = low > high[2] ? 1.0 : high < low[2] ? -1.0 : 0.0
float f9      = useSMC ? f9_raw  : 0.0
bool  bullImpulse = close > high[1] and close > open
bool  bearImpulse = close < low[1]  and close < open
float f10_raw = bullImpulse and close[1] < open[1] ? 1.0 : bearImpulse and close[1] > open[1] ? -1.0 : 0.0
float f10     = useSMC ? f10_raw : 0.0
float f11_raw = close > swingHigh20[1] ? 1.0 : close < swingLow20[1] ? -1.0 : 0.0
float f11     = useSMC ? f11_raw : 0.0
float f12_raw = low < lowest10Low[1] and close > lowest10Low[1] ? 1.0 : high > highest10High[1] and close < highest10High[1] ? -1.0 : 0.0
float f12     = useSMC ? f12_raw : 0.0
float midpt50 = (highest50 + lowest50) / 2.0
float rng50   = math.max(highest50 - lowest50, 0.0001)
float f13_raw = math.max(-1.0, math.min(1.0, (midpt50 - close) / (rng50 * 0.5)))
float f13     = useSMC ? f13_raw : 0.0
bool  higherLow = low > low[1] and low[1] < low[2] and close < maShort
bool  lowerHigh = high < high[1] and high[1] > high[2] and close > maShort
float f14_raw   = higherLow ? 0.7 : lowerHigh ? -0.7 : 0.0
float f14       = useSMC ? f14_raw : 0.0

int   utcHour  = hour(time, "UTC")
float f15_raw  = (utcHour >= 13 and utcHour < 17) ? 1.0 :
                 (utcHour >= 8  and utcHour < 13) ? 0.8 :
                 (utcHour >= 17 and utcHour < 22) ? 0.3 : -0.5
float f15      = useSession ? f15_raw : 0.0

bool  bullAlign = ma50_1h > ma200_1h and close > ma50_4h
bool  bearAlign = ma50_1h < ma200_1h and close < ma50_4h
float f16_raw   = bullAlign ? 1.0 : bearAlign ? -1.0 : 0.0
float f16       = useMTF  ? f16_raw : 0.0

float f17_raw = dxyEma5 < dxyEma20 ? 1.0 : dxyEma5 > dxyEma20 ? -1.0 : 0.0
float f17     = useDXY  ? f17_raw : 0.0

float candleRange = math.max(high - low, 0.0001)
float buyVol      = volume * (close - low)  / candleRange
float sellVol     = volume * (high - close) / candleRange
float avgVol      = ta.sma(volume, 20)
float f18_raw     = math.max(-1.0, math.min(1.0, (buyVol - sellVol) / math.max(avgVol, 0.0001)))
float f18         = useVolDelta ? f18_raw : 0.0

bool  bullDiv = low <= lowestLow14    and rsiVal > rsiLow14
bool  bearDiv = high >= highestHigh14 and rsiVal < rsiHigh14
float f19_raw = bullDiv ? 1.0 : bearDiv ? -1.0 : 0.0
float f19     = useRSIDiv ? f19_raw : 0.0

float rng100     = math.max(highest100 - lowest100, 0.0001)
float fib50      = lowest100 + rng100 * 0.500
float fib618     = lowest100 + rng100 * 0.618
bool  inGBuy     = close >= fib50 and close <= fib618
bool  inGSell    = close >= (highest100 - rng100 * 0.618) and close <= (highest100 - rng100 * 0.500)
float f20_raw    = inGBuy ? 0.8 : inGSell ? -0.8 : math.max(-1.0, math.min(1.0, (close - fib50) / (rng100 * 0.5)))
float f20        = useFib ? f20_raw : 0.0

float vwapVal = ta.vwap(hlc3)
float f21_raw = math.max(-1.0, math.min(1.0, (close - vwapVal) / math.max(atr * 3.0, 0.0001)))
float f21     = useVWAP ? f21_raw : 0.0

float bodySize = math.abs(close - open)
float fullRng  = math.max(high - low, syminfo.mintick)
float bodyDir  = close >= open ? 1.0 : -1.0
float f22_raw  = bodyDir * math.min(bodySize / fullRng, 1.0)
float f22      = useNewFeats ? f22_raw : 0.0

float rsiSlope = (rsiVal - rsiVal[3]) / 3.0
float f23_raw  = math.max(-1.0, math.min(1.0, rsiSlope / 15.0))
float f23      = useNewFeats ? f23_raw : 0.0

float swLow20_2  = ta.lowest(low,  20)[2]
float swHigh20_2 = ta.highest(high, 20)[2]
bool  sweepDown  = low[1] < swLow20_2  and close[1] > swLow20_2
bool  sweepUp    = high[1] > swHigh20_2 and close[1] < swHigh20_2
bool  fvgBullQ   = sweepDown and (low > high[2]) and close > open
bool  fvgBearQ   = sweepUp   and (high < low[2]) and close < open
float f24_raw    = fvgBullQ ? 1.0 : fvgBearQ ? -1.0 : 0.0
float f24        = useNewFeats ? f24_raw : 0.0

float todMins  = float(utcHour * 60 + minute)
float f25_raw  = math.sin((todMins / 1440.0) * 2.0 * math.pi)
float f25      = useNewFeats ? f25_raw : 0.0

// F26: Stochastic %K−%D momentum delta (independent of F6 Williams %R)
float f26_raw  = math.max(-1.0, math.min(1.0, (stochK - stochD) / 20.0))
float f26      = useNewFeats ? f26_raw : 0.0

// ═══════════════════════════════════════════════════════════════════
// ADAPTIVE WEIGHTS — 26 elements
// ═══════════════════════════════════════════════════════════════════
var float[] weights = array.new_float(26, 1.0)
var int totalWins   = 0
var int totalLosses = 0

clampW(w) => math.max(0.2, math.min(3.0, w))

float[] curFeats = array.from(
    f1,  f2,  f3,  f4,  f5,  f6,  f7,  f8,  f9,  f10,
    f11, f12, f13, f14, f15, f16, f17, f18, f19, f20,
    f21, f22, f23, f24, f25, f26)

// ═══════════════════════════════════════════════════════════════════
// LORENTZIAN DISTANCE
// ═══════════════════════════════════════════════════════════════════
lorDist(float[] a, float[] b, float[] w) =>
    float d = 0.0
    for i = 0 to array.size(a) - 1
        d += array.get(w, i) * math.log(1.0 + math.abs(array.get(a, i) - array.get(b, i)))
    d

// ═══════════════════════════════════════════════════════════════════
// KERNEL REGRESSION (price trend filter)
// ═══════════════════════════════════════════════════════════════════
rqKernel(src, h, alpha, window) =>
    float num = 0.0
    float den = 0.0
    for i = 0 to window - 1
        float wk = math.pow(1.0 + float(i * i) / (2.0 * alpha * h * h), -alpha)
        num += src[i] * wk
        den += wk
    den > 0.0 ? num / den : src[0]

float kernelEst = useKernel ? rqKernel(close, kH, kAlpha, kWin) : maShort
bool  kernelUp  = kernelEst > kernelEst[2]
bool  kernelDown = kernelEst < kernelEst[2]

// ═══════════════════════════════════════════════════════════════════
// KNN CLASSIFIER
// ═══════════════════════════════════════════════════════════════════
var float mlBull = 0.5
var float mlBear = 0.5

if bar_index > mlK * 2 + mlLag and bar_index % 2 == 0
    float[] kDist = array.new_float(mlK, 1.0e10)
    int[]   kLbl  = array.new_int(mlK, 0)
    int searchLen = math.min(mlDepth, math.min(bar_index - mlLag - 1, 500))
    int step      = math.max(2, math.round(float(searchLen) / 150.0))
    for i = mlLag + step to searchLen by step
        bool dataOk = not na(f1[i]) and not na(f2[i]) and not na(f9[i])
        if dataOk
            float[] histFeats = array.from(
                f1[i],  f2[i],  f3[i],  f4[i],  f5[i],  f6[i],  f7[i],  f8[i],  f9[i],  f10[i],
                f11[i], f12[i], f13[i], f14[i], f15[i], f16[i], f17[i], f18[i], f19[i], f20[i],
                f21[i], f22[i], f23[i], f24[i], f25[i], f26[i])
            float dist = lorDist(curFeats, histFeats, weights)
            int   lbl  = close[i - mlLag] > close[i] ? 1 : -1
            int   maxIdx = 0
            float maxD   = array.get(kDist, 0)
            for j = 1 to mlK - 1
                if array.get(kDist, j) > maxD
                    maxD   := array.get(kDist, j)
                    maxIdx := j
            if dist < maxD
                array.set(kDist, maxIdx, dist)
                array.set(kLbl,  maxIdx, lbl)
    int bullVotes = 0
    int bearVotes = 0
    for j = 0 to mlK - 1
        if array.get(kLbl, j) == 1
            bullVotes += 1
        else if array.get(kLbl, j) == -1
            bearVotes += 1
    mlBull := bullVotes > 0 or bearVotes > 0 ? float(bullVotes) / float(bullVotes + bearVotes) : 0.5
    mlBear := 1.0 - mlBull

// ═══════════════════════════════════════════════════════════════════
// SIGNAL LOGIC
// ═══════════════════════════════════════════════════════════════════
bool longOk  = mlBull >= mlMinScore and kernelUp  and not isSideways
bool shortOk = mlBear >= mlMinScore and kernelDown and not isSideways

// Debounce — no repeat same direction
var int lastSig = 0   // 1=long, -1=short
bool sigLong  = longOk  and lastSig != 1
bool sigShort = shortOk and lastSig != -1

if sigLong
    lastSig := 1
if sigShort
    lastSig := -1

// ═══════════════════════════════════════════════════════════════════
// ADAPTIVE WEIGHT UPDATE (paper labels — lagged)
// ═══════════════════════════════════════════════════════════════════
var float[] storedFeats = array.new_float(26, 0.0)
var int     storedSig   = 0

if sigLong or sigShort
    for i = 0 to 25
        array.set(storedFeats, i, array.get(curFeats, i))
    storedSig := sigLong ? 1 : -1

// Label close[mlLag] bars ago — did stored signal work?
if bar_index > mlLag + 5 and storedSig != 0
    float priceNow  = close
    float priceEntry = close[mlLag]
    bool  isWin  = storedSig == 1 ? priceNow > priceEntry : priceNow < priceEntry
    bool  isLoss = storedSig == 1 ? priceNow < priceEntry : priceNow > priceEntry
    if isWin
        totalWins += 1
        for i = 0 to 25
            float fv = array.get(storedFeats, i)
            float wv = array.get(weights, i)
            if math.abs(fv) > 0.1
                array.set(weights, i, clampW(wv + winReward * learnRate * math.abs(fv)))
        storedSig := 0
    else if isLoss
        totalLosses += 1
        for i = 0 to 25
            float fv = array.get(storedFeats, i)
            float wv = array.get(weights, i)
            if math.abs(fv) > 0.1
                array.set(weights, i, clampW(wv - lossPenalty * learnRate * math.abs(fv)))
        storedSig := 0

// ═══════════════════════════════════════════════════════════════════
// TP / SL LEVELS
// ═══════════════════════════════════════════════════════════════════
float entryP = close
float tp1L   = sigLong  ? entryP + atr * atrMultTP1 : sigShort ? entryP - atr * atrMultTP1 : na
float tp2L   = sigLong  ? entryP + atr * atrMultTP2 : sigShort ? entryP - atr * atrMultTP2 : na
float tp3L   = sigLong  ? entryP + atr * atrMultTP3 : sigShort ? entryP - atr * atrMultTP3 : na
float slL    = sigLong  ? entryP - atr * atrMultSL  : sigShort ? entryP + atr * atrMultSL  : na

// Pct distance helpers
pctStr(float base, float target) =>
    float pct = math.abs((target - base) / base * 100.0)
    str.tostring(pct, "#.##") + "%"

// ═══════════════════════════════════════════════════════════════════
// SIGNAL LABELS (on chart, historical)
// ═══════════════════════════════════════════════════════════════════
if showLabels
    if sigLong
        string bullPct = str.tostring(math.round(mlBull * 100)) + "%"
        string lblTxt  = "▲ BUY\n" +
                         "Entry: " + str.tostring(entryP, format.mintick) + "\n" +
                         "TP1:   " + str.tostring(tp1L, format.mintick) + "  +" + pctStr(entryP, tp1L) + "\n" +
                         "TP2:   " + str.tostring(tp2L, format.mintick) + "  +" + pctStr(entryP, tp2L) + "\n" +
                         "TP3:   " + str.tostring(tp3L, format.mintick) + "  +" + pctStr(entryP, tp3L) + "\n" +
                         "SL:    " + str.tostring(slL,  format.mintick) + "  -" + pctStr(entryP, slL)  + "\n" +
                         "ML ▲ " + bullPct
        label.new(bar_index, low - atr * 0.4, lblTxt,
                  color=color.new(color.teal, 10), textcolor=color.white,
                  style=label.style_label_up, size=size.small)

    if sigShort
        string bearPct = str.tostring(math.round(mlBear * 100)) + "%"
        string lblTxt  = "▼ SELL\n" +
                         "Entry: " + str.tostring(entryP, format.mintick) + "\n" +
                         "TP1:   " + str.tostring(tp1L, format.mintick) + "  +" + pctStr(entryP, tp1L) + "\n" +
                         "TP2:   " + str.tostring(tp2L, format.mintick) + "  +" + pctStr(entryP, tp2L) + "\n" +
                         "TP3:   " + str.tostring(tp3L, format.mintick) + "  +" + pctStr(entryP, tp3L) + "\n" +
                         "SL:    " + str.tostring(slL,  format.mintick) + "  +" + pctStr(entryP, slL)  + "\n" +
                         "ML ▼ " + bearPct
        label.new(bar_index, high + atr * 0.4, lblTxt,
                  color=color.new(color.red, 10), textcolor=color.white,
                  style=label.style_label_down, size=size.small)

// ═══════════════════════════════════════════════════════════════════
// TP/SL LINES for the LATEST signal only
// ═══════════════════════════════════════════════════════════════════
var line lineTP1 = na
var line lineTP2 = na
var line lineTP3 = na
var line lineSL  = na
var line lineEntry = na

if showLines and (sigLong or sigShort)
    line.delete(lineTP1)
    line.delete(lineTP2)
    line.delete(lineTP3)
    line.delete(lineSL)
    line.delete(lineEntry)
    int ext = 30
    lineEntry := line.new(bar_index, entryP, bar_index + ext, entryP,
                          color=color.new(color.gray, 40), width=1, style=line.style_dashed)
    lineTP1   := line.new(bar_index, tp1L, bar_index + ext, tp1L,
                          color=color.new(color.teal, 20), width=1)
    lineTP2   := line.new(bar_index, tp2L, bar_index + ext, tp2L,
                          color=color.new(color.green, 20), width=2)
    lineTP3   := line.new(bar_index, tp3L, bar_index + ext, tp3L,
                          color=color.new(color.lime, 30), width=1, style=line.style_dotted)
    lineSL    := line.new(bar_index, slL,  bar_index + ext, slL,
                          color=color.new(color.red, 20), width=1)

// ═══════════════════════════════════════════════════════════════════
// TOP FEATURES BY WEIGHT (for dashboard)
// ═══════════════════════════════════════════════════════════════════
string[] fNames = array.from(
    "F1·RSI", "F2·ADX", "F3·ATR", "F4·BB%", "F5·MACD",
    "F6·WillR","F7·CMO","F8·EMA","F9·FVG","F10·Impl",
    "F11·BOS","F12·Liq","F13·Mid","F14·ChoCh","F15·Sess",
    "F16·MTF","F17·DXY","F18·VolΔ","F19·RSIDiv","F20·Fib",
    "F21·VWAP","F22·Body","F23·RSIAcc","F24·FVGQual","F25·TOD",
    "F26·StochΔ")

// Find top 5 weights
topFeats() =>
    string result = ""
    float[] wCopy = array.copy(weights)
    for _t = 0 to 4
        float maxW  = -1.0
        int   maxI  = 0
        for i = 0 to 25
            if array.get(wCopy, i) > maxW
                maxW := array.get(wCopy, i)
                maxI := i
        array.set(wCopy, maxI, -999.0)
        float fval = array.get(curFeats, maxI)
        string dir = fval > 0.1 ? " ▲" : fval < -0.1 ? " ▼" : " –"
        result := result + array.get(fNames, maxI) + str.tostring(array.get(weights, maxI), "#.##") + dir + "\n"
    result

// ═══════════════════════════════════════════════════════════════════
// COMPOSITE SCORE (weighted feature dot product)
// ═══════════════════════════════════════════════════════════════════
float compScore = 0.0
float wSum      = 0.0
for i = 0 to 25
    float w = array.get(weights, i)
    float f = array.get(curFeats, i)
    compScore += w * f
    wSum      += w
float normScore = wSum > 0 ? compScore / wSum : 0.0

// Signal tier based on ML score
signalTier(bullScore, bearScore) =>
    float top = math.max(bullScore, bearScore)
    top >= 0.75 ? "⭐⭐⭐ STRONG" :
     top >= 0.65 ? "⭐⭐ GOOD" :
     top >= 0.55 ? "⭐ MODERATE" : "– WEAK"

// ═══════════════════════════════════════════════════════════════════
// SESSION LABEL
// ═══════════════════════════════════════════════════════════════════
string sessLabel = (utcHour >= 13 and utcHour < 17) ? "NY+Lon Overlap" :
                   (utcHour >= 8  and utcHour < 13) ? "London" :
                   (utcHour >= 17 and utcHour < 22) ? "NY Late" : "Asian"

// ═══════════════════════════════════════════════════════════════════
// DASHBOARD TABLE (bottom-left)
// ═══════════════════════════════════════════════════════════════════
var table dash = table.new(position.bottom_left, 2, 18,
                           bgcolor=color.new(color.black, 15),
                           border_color=color.new(color.gray, 60),
                           border_width=1, frame_color=color.new(color.gray, 40), frame_width=1)

// Helpers
cellL(r, txt, col) => table.cell(dash, 0, r, txt, text_color=color.new(color.gray, 20), text_size=size.small, bgcolor=col)
cellR(r, txt, col) => table.cell(dash, 1, r, txt, text_color=color.white,              text_size=size.small, bgcolor=col)

hdr(r, txt) =>
    table.cell(dash, 0, r, txt, text_color=color.new(color.yellow, 10), text_size=size.small,
               bgcolor=color.new(color.navy, 30))
    table.cell(dash, 1, r, "",  text_color=color.white,                 text_size=size.small,
               bgcolor=color.new(color.navy, 30))

// Colors
color colBull = color.new(color.teal, 20)
color colBear = color.new(color.red,  20)
color colWarn = color.new(color.orange, 30)
color colNeu  = color.new(color.gray,  50)
color colBg   = color.new(color.black, 25)

// Win rate
int   totalTrades = totalWins + totalLosses
float winRate     = totalTrades > 0 ? float(totalWins) / float(totalTrades) * 100.0 : 0.0
color wrColor     = winRate >= 55 ? colBull : winRate >= 45 ? colNeu : colBear

// Signal direction
string sigDir = sigLong ? "▲ LONG" : sigShort ? "▼ SHORT" : "– FLAT"
color  sigClr = sigLong ? colBull  : sigShort  ? colBear  : colNeu

// Regime
color regClr  = isSideways ? colWarn : (mainTrend == "UPTREND" ? colBull : mainTrend == "DOWNTREND" ? colBear : colNeu)

if showDash and barstate.islast
    // Header
    hdr(0, "  AI MLM 26  ·  " + syminfo.ticker + " " + timeframe.period + "m")

    // ML Quality
    hdr(1, "── ML Quality ──")
    cellL(2, "BULL Score",   colBg)
    cellR(2, str.tostring(math.round(mlBull * 100)) + "%",
          mlBull >= mlMinScore ? colBull : colNeu)
    cellL(3, "BEAR Score",   colBg)
    cellR(3, str.tostring(math.round(mlBear * 100)) + "%",
          mlBear >= mlMinScore ? colBear : colNeu)
    cellL(4, "Tier",         colBg)
    cellR(4, signalTier(mlBull, mlBear), colBg)

    // Signal
    hdr(5, "── Signal ──")
    cellL(6, "Direction",    colBg)
    cellR(6, sigDir,         sigClr)
    cellL(7, "Entry",        colBg)
    cellR(7, str.tostring(close, format.mintick), colBg)
    cellL(8, "Composite F",  colBg)
    cellR(8, str.tostring(normScore, "#.##"),
          normScore > 0.1 ? colBull : normScore < -0.1 ? colBear : colNeu)
    cellL(9, "Kernel",       colBg)
    cellR(9, kernelUp ? "▲ UP" : kernelDown ? "▼ DOWN" : "– FLAT",
          kernelUp ? colBull : kernelDown ? colBear : colNeu)

    // Performance
    hdr(10, "── Performance ──")
    cellL(11, "Win Rate",    colBg)
    cellR(11, totalTrades > 0 ? str.tostring(winRate, "#.#") + "% (" + str.tostring(totalTrades) + " trades)" : "– (no data yet)", wrColor)
    cellL(12, "W / L",       colBg)
    cellR(12, str.tostring(totalWins) + " / " + str.tostring(totalLosses), colBg)

    // Context
    hdr(13, "── Context ──")
    cellL(14, "Regime",      colBg)
    cellR(14, isSideways ? "⚠ SIDEWAYS" : mainTrend, regClr)
    cellL(15, "Session",     colBg)
    cellR(15, sessLabel,     colBg)
    cellL(16, "MTF Align",   colBg)
    cellR(16, bullAlign ? "▲ BULL" : bearAlign ? "▼ BEAR" : "– NEUTRAL",
          bullAlign ? colBull : bearAlign ? colBear : colNeu)
    cellL(17, "DXY",         colBg)
    cellR(17, dxyEma5 < dxyEma20 ? "▼ Bearish (↑Gold)" : "▲ Bullish (↓Gold)",
          dxyEma5 < dxyEma20 ? colBull : colBear)

// ── Kernel line on chart ─────────────────────────────────────────
plot(useKernel ? kernelEst : na, "Kernel", color=color.new(color.purple, 40), linewidth=2)

// ── EMA reference lines ───────────────────────────────────────────
plot(maShort, "EMA 50",  color=color.new(color.orange, 60), linewidth=1)
plot(maLong,  "EMA 200", color=color.new(color.blue,   60), linewidth=1)
