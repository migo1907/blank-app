// © Mohamed - Elite Intelligence ULTIMATE LITE - NY Edition
// Built for IC Markets + TradingView - XAU/USD NY Session
// Optimized for: 13:00-16:00 UTC (NY Kill Zone) + 08:00-10:00 UTC (London)
// Signal Frequency: 10-20/day | Simple Logic + Smart Features

//@version=6
indicator("Elite ULTIMATE LITE - NY Edition",
     overlay=true,
     max_labels_count=500,
     max_lines_count=500,
     max_boxes_count=500)

// ═══════════════════════════════════════════════════════════════════════════════
// WEEKLY INTELLIGENCE
// ═══════════════════════════════════════════════════════════════════════════════

regime_score = input.int(0, "Weekly Regime Score (-10 Bear → +10 Bull)",
     minval=-10, maxval=10, step=1,
     group="📊 Weekly Intelligence",
     tooltip="From Claude's Sunday brief. -4 = Bearish, 0 = Neutral, +4 = Bullish")

intelligence_confidence = input.int(75, "Confidence %",
     minval=0, maxval=100, step=5,
     group="📊 Weekly Intelligence")

// ═══════════════════════════════════════════════════════════════════════════════
// NEWS EVENTS
// ═══════════════════════════════════════════════════════════════════════════════

event_1_enabled = input.bool(false, "Event 1 Active?",   group="📅 News Events")
event_1_name    = input.string("",   "Event 1 Name",     group="📅 News Events")
event_1_time    = input.time(timestamp("2026-01-01 00:00"), "Event 1 Time (UTC)", group="📅 News Events")
event_1_impact  = input.string("High", "Event 1 Impact", options=["Medium","High"], group="📅 News Events")

event_2_enabled = input.bool(false, "Event 2 Active?",   group="📅 News Events")
event_2_name    = input.string("",   "Event 2 Name",     group="📅 News Events")
event_2_time    = input.time(timestamp("2026-01-01 00:00"), "Event 2 Time (UTC)", group="📅 News Events")
event_2_impact  = input.string("High", "Event 2 Impact", options=["Medium","High"], group="📅 News Events")

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAL SETTINGS
// ═══════════════════════════════════════════════════════════════════════════════

rsi_oversold    = input.int(40,  "RSI Oversold Level",       minval=20, maxval=50,  group="🎯 Signal Settings")
rsi_overbought  = input.int(60,  "RSI Overbought Level",     minval=50, maxval=80,  group="🎯 Signal Settings")
min_risk_reward = input.float(1.5,"Min Risk:Reward",         minval=1.0, maxval=5.0, step=0.5, group="🎯 Signal Settings")
tp_atr_mult     = input.float(2.5,"Take Profit (ATR Mult)",  minval=1.0, maxval=10.0, step=0.5, group="🎯 Signal Settings")
sl_atr_mult     = input.float(1.5,"Stop Loss (ATR Mult)",    minval=0.5, maxval=3.0,  step=0.1, group="🎯 Signal Settings")

use_fvg           = input.bool(true,  "Use Fair Value Gaps",  group="💎 Smart Features")
use_order_blocks  = input.bool(true,  "Use Order Blocks",     group="💎 Smart Features")
use_liquidity     = input.bool(true,  "Use Liquidity Sweeps", group="💎 Smart Features")
use_regime_filter = input.bool(true,  "Use Regime Filter",    group="💎 Smart Features",
     tooltip="In bearish regime, reduce long signals. In bullish, reduce shorts.")

show_fvg_boxes = input.bool(false, "Show FVG Boxes on Chart",         group="🎨 Display")
show_ob_boxes  = input.bool(false, "Show Order Block Boxes on Chart",  group="🎨 Display")

// ═══════════════════════════════════════════════════════════════════════════════
// CORE INDICATORS
// ═══════════════════════════════════════════════════════════════════════════════

rsi    = ta.rsi(close, 14)
atr    = ta.atr(14)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

rsi_4h = request.security(syminfo.tickerid, "240", ta.rsi(close, 14), lookahead=barmerge.lookahead_off)
rsi_1h = request.security(syminfo.tickerid, "60",  ta.rsi(close, 14), lookahead=barmerge.lookahead_off)

normal_volume = ta.sma(volume, 20)
high_volume   = volume > normal_volume * 1.5

swing_high = ta.pivothigh(high, 5, 5)
swing_low  = ta.pivotlow(low,  5, 5)

var float last_swing_high = na
var float last_swing_low  = na
if not na(swing_high)
    last_swing_high := swing_high
if not na(swing_low)
    last_swing_low := swing_low

// ═══════════════════════════════════════════════════════════════════════════════
// SESSION DETECTION & KILL ZONES
// ═══════════════════════════════════════════════════════════════════════════════

current_hour = hour(time, "UTC")

in_london_kz = current_hour >= 8  and current_hour < 10
in_ny_kz     = current_hour >= 13 and current_hour < 16
in_kill_zone = in_london_kz or in_ny_kz
in_dead_zone = current_hour >= 21 or current_hour <= 1

bgcolor(in_ny_kz     ? color.new(color.green, 92) : na, title="NY Kill Zone")
bgcolor(in_london_kz ? color.new(color.blue,  95) : na, title="London Kill Zone")
bgcolor(in_dead_zone ? color.new(color.red,   97) : na, title="Dead Zone")

// ═══════════════════════════════════════════════════════════════════════════════
// FAIR VALUE GAPS  — float arrays drive detection; boxes are display-only
// ═══════════════════════════════════════════════════════════════════════════════

bullish_fvg    = use_fvg and low > high[2]
bearish_fvg    = use_fvg and high < low[2]

// Detection arrays (always populated)
var float[] bfvg_top = array.new<float>()
var float[] bfvg_bot = array.new<float>()
var float[] sfvg_top = array.new<float>()
var float[] sfvg_bot = array.new<float>()

if bullish_fvg
    if array.size(bfvg_top) >= 3
        array.shift(bfvg_top)
        array.shift(bfvg_bot)
    array.push(bfvg_top, low)
    array.push(bfvg_bot, high[2])
    if show_fvg_boxes
        box.new(bar_index, low, bar_index + 30, high[2],
             bgcolor=color.new(color.green, 85), border_color=color.new(color.green, 50), border_width=1)

if bearish_fvg
    if array.size(sfvg_top) >= 3
        array.shift(sfvg_top)
        array.shift(sfvg_bot)
    array.push(sfvg_top, low[2])
    array.push(sfvg_bot, high)
    if show_fvg_boxes
        box.new(bar_index, low[2], bar_index + 30, high,
             bgcolor=color.new(color.red, 85), border_color=color.new(color.red, 50), border_width=1)

in_bullish_fvg = false
if array.size(bfvg_top) > 0
    for i = 0 to array.size(bfvg_top) - 1
        if close >= array.get(bfvg_bot, i) and close <= array.get(bfvg_top, i)
            in_bullish_fvg := true
            break

in_bearish_fvg = false
if array.size(sfvg_top) > 0
    for i = 0 to array.size(sfvg_top) - 1
        if close >= array.get(sfvg_bot, i) and close <= array.get(sfvg_top, i)
            in_bearish_fvg := true
            break

// ═══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCKS  — same pattern: float arrays for detection, boxes for display
// ═══════════════════════════════════════════════════════════════════════════════

var float[] bob_top = array.new<float>()
var float[] bob_bot = array.new<float>()
var float[] sob_top = array.new<float>()
var float[] sob_bot = array.new<float>()

bullish_ob_detected = false
bullish_ob_high     = 0.0
bullish_ob_low      = 0.0

if use_order_blocks
    for i = 1 to 20
        if close[i] < open[i] and volume[i] > normal_volume[i] * 1.3
            if close > high[i] and (close - low[i]) > atr * 1.5
                bullish_ob_detected := true
                bullish_ob_high     := high[i]
                bullish_ob_low      := low[i]
                break

bearish_ob_detected = false
bearish_ob_high     = 0.0
bearish_ob_low      = 0.0

if use_order_blocks
    for i = 1 to 20
        if close[i] > open[i] and volume[i] > normal_volume[i] * 1.3
            if close < low[i] and (high[i] - close) > atr * 1.5
                bearish_ob_detected := true
                bearish_ob_high     := high[i]
                bearish_ob_low      := low[i]
                break

if bullish_ob_detected
    if array.size(bob_top) >= 2
        array.shift(bob_top)
        array.shift(bob_bot)
    array.push(bob_top, bullish_ob_high)
    array.push(bob_bot, bullish_ob_low)
    if show_ob_boxes
        box.new(bar_index, bullish_ob_high, bar_index + 30, bullish_ob_low,
             bgcolor=color.new(color.blue, 80), border_color=color.new(color.blue, 30), border_width=2)

if bearish_ob_detected
    if array.size(sob_top) >= 2
        array.shift(sob_top)
        array.shift(sob_bot)
    array.push(sob_top, bearish_ob_high)
    array.push(sob_bot, bearish_ob_low)
    if show_ob_boxes
        box.new(bar_index, bearish_ob_high, bar_index + 30, bearish_ob_low,
             bgcolor=color.new(color.purple, 80), border_color=color.new(color.purple, 30), border_width=2)

in_bullish_ob = false
if array.size(bob_top) > 0
    for i = 0 to array.size(bob_top) - 1
        if close >= array.get(bob_bot, i) and close <= array.get(bob_top, i)
            in_bullish_ob := true
            break

in_bearish_ob = false
if array.size(sob_top) > 0
    for i = 0 to array.size(sob_top) - 1
        if close >= array.get(sob_bot, i) and close <= array.get(sob_top, i)
            in_bearish_ob := true
            break

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY SWEEPS  (detection only — no chart labels for cleaner view)
// ═══════════════════════════════════════════════════════════════════════════════

var float[] recent_highs     = array.new<float>()
var int[]   recent_high_bars = array.new<int>()
var float[] recent_lows      = array.new<float>()
var int[]   recent_low_bars  = array.new<int>()

if not na(swing_high)
    array.push(recent_highs, swing_high)
    array.push(recent_high_bars, bar_index)
    if array.size(recent_highs) > 10
        array.shift(recent_highs)
        array.shift(recent_high_bars)

if not na(swing_low)
    array.push(recent_lows, swing_low)
    array.push(recent_low_bars, bar_index)
    if array.size(recent_lows) > 10
        array.shift(recent_lows)
        array.shift(recent_low_bars)

bullish_sweep = false
bearish_sweep = false

if use_liquidity and array.size(recent_lows) > 0
    for i = 0 to array.size(recent_lows) - 1
        liq_low = array.get(recent_lows, i)
        if low[1] < liq_low and close > open and close > liq_low
            bullish_sweep := true
            break

if use_liquidity and array.size(recent_highs) > 0
    for i = 0 to array.size(recent_highs) - 1
        liq_high = array.get(recent_highs, i)
        if high[1] > liq_high and close < open and close < liq_high
            bearish_sweep := true
            break

// ═══════════════════════════════════════════════════════════════════════════════
// NEWS EVENT DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

f_in_event_window(enabled, evt_time, impact) =>
    if not enabled
        false
    else
        buf_before = impact == "High" ? 30 * 60000 : 15 * 60000
        buf_after  = impact == "High" ? 60 * 60000 : 30 * 60000
        time >= evt_time - buf_before and time <= evt_time + buf_after

in_event_1 = f_in_event_window(event_1_enabled, event_1_time, event_1_impact)
in_event_2 = f_in_event_window(event_2_enabled, event_2_time, event_2_impact)
news_pause  = in_event_1 or in_event_2

var string next_event = ""
if event_1_enabled and time < event_1_time
    next_event := event_1_name
else if event_2_enabled and time < event_2_time
    next_event := event_2_name

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAL LOGIC
// ═══════════════════════════════════════════════════════════════════════════════

base_buy_signal  = ta.crossover(rsi, rsi_oversold)   and close > low[1]
base_sell_signal = ta.crossunder(rsi, rsi_overbought) and close < high[1]

regime_allows_long  = not use_regime_filter or regime_score >= -3
regime_allows_short = not use_regime_filter or regime_score <= 3

can_trade = not in_dead_zone and not news_pause

buy_conditions  = base_buy_signal  and regime_allows_long  and can_trade
sell_conditions = base_sell_signal and regime_allows_short and can_trade

sl_long  = na(last_swing_low)  ? close - atr * sl_atr_mult : last_swing_low  - atr * 0.5
sl_short = na(last_swing_high) ? close + atr * sl_atr_mult : last_swing_high + atr * 0.5
tp_long  = close + atr * tp_atr_mult
tp_short = close - atr * tp_atr_mult

risk_long  = close - sl_long
risk_short = sl_short - close

rr_long  = risk_long  > 0 ? (tp_long  - close) / risk_long  : 0.0
rr_short = risk_short > 0 ? (close - tp_short)  / risk_short : 0.0

buy_signal  = buy_conditions  and rr_long  >= min_risk_reward
sell_signal = sell_conditions and rr_short >= min_risk_reward

// Signal quality score
var int signal_quality = 50

if buy_signal or sell_signal
    q = 50
    if in_kill_zone
        q := q + 15
    if buy_signal and in_bullish_fvg
        q := q + 10
    if sell_signal and in_bearish_fvg
        q := q + 10
    if buy_signal and in_bullish_ob
        q := q + 10
    if sell_signal and in_bearish_ob
        q := q + 10
    if buy_signal and bullish_sweep
        q := q + 15
    if sell_signal and bearish_sweep
        q := q + 15
    if high_volume
        q := q + 5
    if rsi_4h < 30 and buy_signal
        q := q + 10
    if rsi_4h > 70 and sell_signal
        q := q + 10
    signal_quality := math.min(q, 95)

// ═══════════════════════════════════════════════════════════════════════════════
// TRADE STATE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

var string active_trade    = "NONE"
var float  entry_price     = 0.0
var float  tp_price        = 0.0
var float  sl_price        = 0.0
var int    trade_confidence = 0

if buy_signal and active_trade == "NONE"
    active_trade     := "LONG"
    entry_price      := close
    tp_price         := tp_long
    sl_price         := sl_long
    trade_confidence := signal_quality

    label.new(bar_index, low,
         "🟢 BUY" +
         "\nEntry: " + str.tostring(close,    "#.00") +
         "\nTP: "    + str.tostring(tp_long,  "#.00") +
         "\nSL: "    + str.tostring(sl_long,  "#.00") +
         "\nConf: "  + str.tostring(signal_quality) + "%" +
         (in_kill_zone ? " 🎯" : ""),
         style=label.style_label_up,
         color=color.new(color.green, 0),
         textcolor=color.white,
         size=size.normal)

if sell_signal and active_trade == "NONE"
    active_trade     := "SHORT"
    entry_price      := close
    tp_price         := tp_short
    sl_price         := sl_short
    trade_confidence := signal_quality

    label.new(bar_index, high,
         "🔴 SELL" +
         "\nEntry: " + str.tostring(close,    "#.00") +
         "\nTP: "    + str.tostring(tp_short, "#.00") +
         "\nSL: "    + str.tostring(sl_short, "#.00") +
         "\nConf: "  + str.tostring(signal_quality) + "%" +
         (in_kill_zone ? " 🎯" : ""),
         style=label.style_label_down,
         color=color.new(color.red, 0),
         textcolor=color.white,
         size=size.normal)

if active_trade == "LONG"  and (high >= tp_price or low  <= sl_price)
    active_trade := "NONE"
if active_trade == "SHORT" and (low  <= tp_price or high >= sl_price)
    active_trade := "NONE"

// ═══════════════════════════════════════════════════════════════════════════════
// TP / SL LINES
// ═══════════════════════════════════════════════════════════════════════════════

if buy_signal
    line.new(bar_index, sl_long,     bar_index + 20, sl_long,
         color=color.new(color.red,  20), width=2, style=line.style_dashed)
    line.new(bar_index, close,       bar_index + 20, close,
         color=color.new(color.gray, 60), width=1, style=line.style_dotted)
    line.new(bar_index, tp_long,     bar_index + 20, tp_long,
         color=color.new(color.lime, 20), width=2, style=line.style_solid)

if sell_signal
    line.new(bar_index, sl_short,    bar_index + 20, sl_short,
         color=color.new(color.red,  20), width=2, style=line.style_dashed)
    line.new(bar_index, close,       bar_index + 20, close,
         color=color.new(color.gray, 60), width=1, style=line.style_dotted)
    line.new(bar_index, tp_short,    bar_index + 20, tp_short,
         color=color.new(color.lime, 20), width=2, style=line.style_solid)

// ═══════════════════════════════════════════════════════════════════════════════
// DASHBOARD  (4 cols × 10 rows — structure unchanged from original)
// ═══════════════════════════════════════════════════════════════════════════════

var table hub = table.new(position.bottom_left, 4, 10,
     bgcolor=color.rgb(10, 10, 10), border_color=color.gray, border_width=1)

if barstate.islast
    // Row 0 — Header
    table.cell(hub, 0, 0, "ELITE ULTIMATE LITE - NY",
         text_color=color.white, bgcolor=color.new(color.blue, 20), text_size=size.normal)
    table.merge_cells(hub, 0, 0, 3, 0)

    // Row 1 — Signal
    sig_color = active_trade == "LONG"  ? color.lime :
                active_trade == "SHORT" ? color.red  : color.yellow
    sig_text  = active_trade == "LONG"  ? "▲  LONG" :
                active_trade == "SHORT" ? "▼  SHORT" : "— WAITING"
    table.cell(hub, 0, 1, "SIGNAL", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 1, sig_text,  text_color=sig_color,  text_size=size.normal)
    table.merge_cells(hub, 1, 1, 3, 1)

    // Row 2 — Confidence | Session
    conf_color = trade_confidence > 75 ? color.lime :
                 trade_confidence > 60 ? color.yellow : color.orange
    table.cell(hub, 0, 2, "CONFIDENCE", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 2, str.tostring(trade_confidence) + "%",
         text_color=conf_color, text_size=size.normal)

    session_text  = in_ny_kz     ? "NY 🎯"   :
                    in_london_kz ? "LONDON"   :
                    in_dead_zone ? "DEAD 🛑"  : "Asian"
    session_color = in_ny_kz     ? color.lime :
                    in_london_kz ? color.aqua :
                    in_dead_zone ? color.red  : color.gray
    table.cell(hub, 2, 2, "SESSION",     text_color=color.gray,  text_size=size.small)
    table.cell(hub, 3, 2, session_text,  text_color=session_color, text_size=size.normal)

    // Row 3 — Entry | 4H RSI
    table.cell(hub, 0, 3, "ENTRY", text_color=color.gray, text_size=size.small)
    entry_disp = active_trade != "NONE" ? str.tostring(entry_price, "#.00") : "WAIT"
    table.cell(hub, 1, 3, entry_disp, text_color=color.white, text_size=size.normal)

    rsi_color = rsi_4h < 30 ? color.lime : rsi_4h > 70 ? color.red : color.yellow
    table.cell(hub, 2, 3, "4H RSI",                          text_color=color.gray,  text_size=size.small)
    table.cell(hub, 3, 3, str.tostring(rsi_4h, "#.0"),       text_color=rsi_color,   text_size=size.normal)

    // Row 4 — Take Profit (full width)
    table.cell(hub, 0, 4, "TAKE PROFIT", text_color=color.gray, text_size=size.small)
    tp_disp = active_trade != "NONE" ? str.tostring(tp_price, "#.00") : "—"
    table.cell(hub, 1, 4, tp_disp, text_color=color.lime, text_size=size.normal)
    table.merge_cells(hub, 1, 4, 3, 4)

    // Row 5 — Stop Loss (full width)
    table.cell(hub, 0, 5, "STOP LOSS", text_color=color.gray, text_size=size.small)
    sl_disp = active_trade != "NONE" ? str.tostring(sl_price, "#.00") : "—"
    table.cell(hub, 1, 5, sl_disp, text_color=color.red, text_size=size.normal)
    table.merge_cells(hub, 1, 5, 3, 5)

    // Row 6 — Regime | Smart Money
    regime_text  = regime_score > 3  ? "BULL 🐂" :
                   regime_score < -3 ? "BEAR 🐻" : "NEUTRAL"
    regime_color = regime_score > 3  ? color.lime :
                   regime_score < -3 ? color.red  : color.yellow
    table.cell(hub, 0, 6, "REGIME",    text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 6, regime_text, text_color=regime_color, text_size=size.normal)

    smart_active = in_bullish_fvg or in_bearish_fvg or in_bullish_ob or in_bearish_ob
    table.cell(hub, 2, 6, "SMART $", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 6, smart_active ? "ACTIVE" : "Clear",
         text_color=smart_active ? color.lime : color.gray, text_size=size.normal)

    // Row 7 — Status (full width)
    status_text  = news_pause   ? "PRE-EVENT 🛑"  :
                   in_dead_zone ? "DEAD ZONE 🛑"  :
                   in_ny_kz     ? "NY LIVE 🎯"    :
                   in_london_kz ? "LONDON 🟢"     : "Monitoring"
    status_color = news_pause or in_dead_zone ? color.red :
                   in_kill_zone ? color.lime : color.yellow
    table.cell(hub, 0, 7, "STATUS",     text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 7, status_text,  text_color=status_color, text_size=size.normal)
    table.merge_cells(hub, 1, 7, 3, 7)

    // Row 8 — Bias (full width)
    bias_text  = close > ema200 ? "▲ Bullish Trend" :
                 close < ema200 ? "▼ Bearish Trend" : "◆ Ranging"
    bias_color = close > ema200 ? color.lime :
                 close < ema200 ? color.red  : color.yellow
    table.cell(hub, 0, 8, "BIAS",     text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 8, bias_text,  text_color=bias_color, text_size=size.small)
    table.merge_cells(hub, 1, 8, 3, 8)

    // Row 9 — News
    table.cell(hub, 0, 9, "NEWS", text_color=color.gray, text_size=size.small)
    if next_event != ""
        table.cell(hub, 1, 9, next_event, text_color=color.yellow, text_size=size.tiny)
        table.merge_cells(hub, 1, 9, 3, 9)
    else
        table.cell(hub, 1, 9, "Clear ✅", text_color=color.lime, text_size=size.small)
        table.merge_cells(hub, 1, 9, 3, 9)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS  — const string only (fixes CE10123)
// ═══════════════════════════════════════════════════════════════════════════════

alertcondition(buy_signal,
     "Buy Signal",
     "🟢 BUY — Check dashboard for Entry / TP / SL")

alertcondition(sell_signal,
     "Sell Signal",
     "🔴 SELL — Check dashboard for Entry / TP / SL")

alertcondition(in_ny_kz and not in_ny_kz[1],
     "NY Session Start",
     "🇺🇸 NY KILL ZONE ACTIVE (13:00 UTC) - Prime trading time!")

alertcondition(in_london_kz and not in_london_kz[1],
     "London Session Start",
     "🇬🇧 LONDON KILL ZONE ACTIVE (08:00 UTC)")

alertcondition(bullish_sweep,
     "Bullish Sweep",
     "LIQUIDITY SWEEP ↑ - Reversal likely")

alertcondition(bearish_sweep,
     "Bearish Sweep",
     "LIQUIDITY SWEEP ↓ - Reversal likely")

// ═══════════════════════════════════════════════════════════════════════════════
// EMA PLOTS
// ═══════════════════════════════════════════════════════════════════════════════

plot(ema50,  "EMA 50",  color=color.new(color.blue,   50), linewidth=1)
plot(ema200, "EMA 200", color=color.new(color.orange, 50), linewidth=2)
