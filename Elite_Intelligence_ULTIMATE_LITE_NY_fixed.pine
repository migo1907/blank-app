// ALERTS  (const string — CE10123 fix)
// ═══════════════════════════════════════════════════════════════════════════════

alertcondition(buy_signal,
     "Buy Signal",
     "BUY Signal fired — check dashboard for Entry / TP / SL")

alertcondition(sell_signal,
     "Sell Signal",
     "SELL Signal fired — check dashboard for Entry / TP / SL")

alertcondition(in_ny_kz and not in_ny_kz[1],
     "NY Session Start",
     "NY KILL ZONE ACTIVE (13:00 UTC) — Prime trading time!")

alertcondition(in_london_kz and not in_london_kz[1],
     "London Session Start",
     "LONDON KILL ZONE ACTIVE (08:00 UTC)")

alertcondition(bullish_sweep,
     "Bullish Sweep",
     "LIQUIDITY SWEEP UP — Bullish reversal likely")

alertcondition(bearish_sweep,
     "Bearish Sweep",
     "LIQUIDITY SWEEP DOWN — Bearish reversal likely")

