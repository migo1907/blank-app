//@version=6
indicator("XAU/USD Migo VS Market Sniper Pro", overlay=true, max_labels_count=500, max_lines_count=500)

// --- INPUTS ---
int lookback        = input.int(50, "Structural Lookback")
float atrMultTP1    = input.float(1.5, "TP1 ATR Multiplier (Partial)")
float atrMultTP2    = input.float(2.5, "TP2 ATR Multiplier")
float atrMultTP3    = input.float(4.0, "TP3 ATR Multiplier (Runner)")
float atrMultSL     = input.float(1.5, "SL ATR Multiplier")
float trailMult     = input.float(1.2, "Trail Stop ATR Multiplier")
bool  useTrail      = input.bool(true, "Activate Trailing Stop (after TP1)")
float tpProximity   = input.float(80.0, "Near-TP Reset Threshold %", minval=50, maxval=99) / 100.0
int adxLen          = input.int(14, "ADX Length")
float adxThreshold  = input.float(20.0, "ADX Sideways Threshold")
float atrRangeRatio = input.float(0.75, "ATR Range Ratio (below = compressed)")
float emaBandPct    = input.float(0.3, "EMA Band % (50/200 too close)")

// --- REALISTIC SL/TP INPUTS ---
bool  useStructure  = input.bool(true,  "Use Market Structure for SL/TP", group="Realistic Levels")
int   swingLookback = input.int(10,     "Swing Lookback (protective SL)", minval=3, group="Realistic Levels")
float slBufferMult  = input.float(0.7,  "SL Structure Buffer (ATR)", minval=0.0, group="Realistic Levels")
float maxSLMult     = input.float(2.5,  "Max SL Distance (ATR cap)", minval=0.5, group="Realistic Levels")
float minSLMult     = input.float(0.8,  "Min SL Distance (ATR floor)", minval=0.1, group="Realistic Levels")
float beBufferMult  = input.float(0.1,  "Breakeven Lock Buffer (ATR) at TP1", minval=0.0, group="Realistic Levels")
bool  autoAdaptive  = input.bool(true,  "Auto-adapt SL/TP/Trail to volatility & trend", group="Realistic Levels")
float adaptStrength = input.float(1.0,  "Adaptation Strength (0 = off, 2 = aggressive)", minval=0.0, maxval=2.0, group="Realistic Levels")
bool  useRRtps      = input.bool(true,  "TPs as Risk:Reward of actual SL", group="Realistic Levels")
float rrTP1         = input.float(1.0,  "TP1 Risk:Reward", minval=0.25, group="Realistic Levels")
float rrTP2         = input.float(2.0,  "TP2 Risk:Reward", minval=0.5, group="Realistic Levels")
float rrTP3         = input.float(3.5,  "TP3 Risk:Reward", minval=1.0, group="Realistic Levels")

// --- RE-ENTRY INPUTS ---
bool  useReEntry    = input.bool(true,  "Enable Pullback Re-Entry Level", group="Re-Entry")
float reEntryRatio  = input.float(0.4,  "Re-Entry Pullback (fraction of risk)", minval=0.1, maxval=0.9, group="Re-Entry")

// --- SIGNAL FILTERS (avoid sideways) ---
bool requireHTFTrend = input.bool(true, "Only trade with HTF-1 trend (skip ranging)", group="Signal Filters")
bool require4H       = input.bool(true, "Also require HTF-2 trend alignment", group="Signal Filters")
bool autoHTF         = input.bool(true, "Auto higher timeframes (standard TF per chart)", group="Signal Filters")
bool requireADXtrend = input.bool(true, "Require ADX above threshold on signal", group="Signal Filters")
bool requireExpansion = input.bool(true, "Require ATR not compressed on signal", group="Signal Filters")
bool pullbackMode    = input.bool(true, "Pullback entry (buy dips / sell rallies)", group="Signal Filters")
int  pbEmaLen        = input.int(20,   "Pullback value EMA length", minval=5, group="Signal Filters")
bool strongConfirm   = input.bool(true, "Strong confirmation (candle close + RSI rising)", group="Signal Filters")
float closeFrac      = input.float(0.33, "Confirm candle close in top/bottom fraction", minval=0.1, maxval=0.5, group="Signal Filters")
bool momoEntry       = input.bool(true, "Momentum breakout entry (catch strong moves)", group="Signal Filters")
int  brkLen          = input.int(10,   "Breakout lookback (bars)", minval=3, group="Signal Filters")
bool noCtFilterLowTF = input.bool(true, "No counter-trend filter on 5m & lower (scalp both ways)", group="Signal Filters")
bool confirmOnClose  = input.bool(true, "Confirm signals on bar close (no repaint)", group="Signal Filters")

// --- SESSION FILTER (avoid noisy hours) ---
bool   useSessions = input.bool(true,  "Restrict signals to selected sessions", group="Sessions")
string sessTZ      = input.string("UTC", "Session Timezone", options=["UTC", "America/New_York", "Europe/London", "Asia/Tokyo", "Asia/Dubai"], group="Sessions")
bool   tradeAsia   = input.bool(false, "Trade Asia session", group="Sessions")
string asiaSess    = input.session("0000-0800", "Asia hours", group="Sessions")
bool   tradeLondon = input.bool(true,  "Trade London session", group="Sessions")
string londonSess  = input.session("0700-1600", "London hours", group="Sessions")
bool   tradeNY     = input.bool(true,  "Trade New York session", group="Sessions")
string nySess      = input.session("1200-2100", "New York hours", group="Sessions")

// --- CALCULATIONS ---
float rsiValue = ta.rsi(close, 14)
float maLong   = ta.ema(close, 200)
float maShort  = ta.ema(close, 50)
float atr      = ta.atr(14)
float atrSma   = ta.sma(atr, 20)
float ema20    = ta.ema(close, pbEmaLen)   // pullback "value" zone

// --- ADX ---
[diPlus, diMinus, adxValue] = ta.dmi(adxLen, adxLen)

// --- SIDEWAYS DETECTION ---
bool adxFlat       = adxValue < adxThreshold
bool atrCompressed = atr < (atrSma * atrRangeRatio)
bool emaTooClose   = math.abs(maShort - maLong) / maLong * 100 < emaBandPct
int sidewaysCount  = (adxFlat ? 1 : 0) + (atrCompressed ? 1 : 0) + (emaTooClose ? 1 : 0)
bool isSideways    = sidewaysCount >= 2

// --- HTF TREND (auto higher timeframes, dual confluence) ---
// Snaps to STANDARD timeframes that traders actually watch, scaled to the chart:
//   <=1m -> 15m / 1h    |   2-3m -> 30m / 2h   |   5-15m -> 1h / 4h
//   30m-1h -> 4h / D    |   >1h  -> D  / W
// (Falls back to fixed 1H / 4H when "Auto higher timeframes" is off.)
int    baseMin = timeframe.in_seconds() / 60
string htf1 = not autoHTF ? "60"  : baseMin <= 1 ? "15"  : baseMin <= 3 ? "30"  : baseMin <= 15 ? "60"  : baseMin <= 60 ? "240" : "D"
string htf2 = not autoHTF ? "240" : baseMin <= 1 ? "60"  : baseMin <= 3 ? "120" : baseMin <= 15 ? "240" : baseMin <= 60 ? "D"   : "W"
string lbl1 = not autoHTF ? "1h"  : baseMin <= 1 ? "15m" : baseMin <= 3 ? "30m" : baseMin <= 15 ? "1h"  : baseMin <= 60 ? "4h"  : "D"
string lbl2 = not autoHTF ? "4h"  : baseMin <= 1 ? "1h"  : baseMin <= 3 ? "2h"  : baseMin <= 15 ? "4h"  : baseMin <= 60 ? "D"   : "W"
float ma50_1h  = request.security(syminfo.tickerid, htf1, ta.ema(close, 50), lookahead=barmerge.lookahead_off)
float rsi_1h   = request.security(syminfo.tickerid, htf1, ta.rsi(close, 14), lookahead=barmerge.lookahead_off)
float ma50_4h  = request.security(syminfo.tickerid, htf2, ta.ema(close, 50), lookahead=barmerge.lookahead_off)
float rsi_4h   = request.security(syminfo.tickerid, htf2, ta.rsi(close, 14), lookahead=barmerge.lookahead_off)
string trend1h = (close > ma50_1h and rsi_1h > 50) ? "UPTREND" : (close < ma50_1h and rsi_1h < 50) ? "DOWNTREND" : "SIDEWAYS"
string trend4h = (close > ma50_4h and rsi_4h > 50) ? "UPTREND" : (close < ma50_4h and rsi_4h < 50) ? "DOWNTREND" : "SIDEWAYS"
string mainTrend = trend1h   // HTF-1 remains the primary trend for confidence/dashboard

// --- AUTO-LEVELS ---
float dynResist  = ta.highest(high, lookback)
float dynSupport = ta.lowest(low, lookback)

// --- PROTECTIVE SWING LEVELS (for structural SL) ---
float swingLow   = ta.lowest(low, swingLookback)
float swingHigh  = ta.highest(high, swingLookback)

// --- ADAPTIVE ENGINE (auto-tunes SL / TP / Trail to live market state) ---
// volFactor: current volatility vs its 20-bar average (clamped) -> widens stops/targets in high vol
// trendStr : 0 at the ADX threshold, 1 once ADX is +20 above it -> extends targets & loosens trail in strong trends
float volFactor = math.max(0.7, math.min(1.6, atr / atrSma))
float trendStr  = math.max(0.0, math.min(1.0, (adxValue - adxThreshold) / 20.0))
float kAdapt    = autoAdaptive ? adaptStrength : 0.0
float fVol      = autoAdaptive ? volFactor : 1.0

// Effective (auto) multipliers — fall back to the raw inputs when auto is off
float effSLmult = atrMultSL  * fVol
float effTrail  = trailMult  * fVol * (1.0 + 0.50 * trendStr * kAdapt)
float effRR1    = rrTP1
float effRR2    = rrTP2 + (0.5 * trendStr * kAdapt)
float effRR3    = rrTP3 + (1.5 * trendStr * kAdapt)
float effTP1m   = atrMultTP1 * fVol
float effTP2m   = atrMultTP2 * fVol * (1.0 + 0.30 * trendStr * kAdapt)
float effTP3m   = atrMultTP3 * fVol * (1.0 + 0.60 * trendStr * kAdapt)

// --- TRADE STATE ---
var string activeTrade  = "NONE"
var float  entryPrice   = 0.0
var float  tp1Price     = 0.0
var float  tp2Price     = 0.0
var float  tp3Price     = 0.0
var float  slPrice      = 0.0
var float  reEntryPrice = 0.0
var int    tradeConf    = 0

// --- LAST SIGNAL TIMESTAMP ---
var int    lastSigBar   = na    // bar_index of the most recent signal
var int    lastSigTime  = na    // time (ms) of the most recent signal
var string lastSigDir   = "—"   // direction of the most recent signal

// --- WIN/LOSS TRACKING ---
// Win  = exited via TP3, OR via the trail/locked SL after TP1/TP2 (always >= breakeven),
//        OR flipped by an opposite signal while in profit
// Loss = hit the original hard SL before TP1, OR flipped by an opposite signal while in loss
var int    tradeWins    = 0
var int    tradeLosses  = 0

// --- TP STAGE REACH COUNTERS (how far winners get) ---
// reachedTP1 = trades that tagged TP1; reachedTP2 = of those, how many went on to TP2; etc.
// "trailed out after TP1" = reachedTP1 - reachedTP2 ; "after TP2" = reachedTP2 - reachedTP3
var int    reachedTP1   = 0
var int    reachedTP2   = 0
var int    reachedTP3   = 0

// --- EXPECTANCY (R-multiple) TRACKING ---
// initRisk = entry-to-initial-SL distance (=1R). Each closed trade adds its realized
// R (exit vs entry / initRisk) so we can read avg R, total R and profit factor.
var float  initRisk     = na
var float  totalR       = 0.0
var float  grossWinR    = 0.0
var float  grossLossR   = 0.0
var int    rTrades      = 0

// Helper applied inline at every exit: record realized R for one closed trade
f_recordR(float exitPx, float entryPx, float risk, bool isLong) =>
    float rMult = (na(risk) or risk <= 0) ? 0.0 : (isLong ? (exitPx - entryPx) / risk : (entryPx - exitPx) / risk)
    rMult

// TP stage tracking
var bool   tp1Hit       = false
var bool   tp2Hit       = false
var bool   reEntryTagged = false
var float  trailSL      = 0.0   // dynamic trailing stop after TP1
var float  lockSL       = na    // hard profit floor — SL can never cross back below/above this

// --- ALERT EVENT FLAGS (reset each bar, set true when an event fires) ---
bool evtTP1 = false
bool evtTP2 = false
bool evtTP3 = false
bool evtSL  = false
bool evtReentry = false

// --- TRAIL STOP UPDATE (runs every bar while in trade) ---
// lockSL guarantees a green position never flips red: once TP1 hits it sits at
// breakeven(+buffer), and once TP2 hits it ratchets up to the TP1 profit.
if activeTrade == "LONG" and tp1Hit
    if useTrail
        float newTrail = high - (atr * effTrail)
        trailSL := math.max(trailSL, newTrail)   // only moves up, never down
    trailSL := math.max(trailSL, lockSL)         // never below the locked profit floor
    slPrice := useTrail ? trailSL : lockSL       // trail off -> stop sits at the lock only

if activeTrade == "SHORT" and tp1Hit
    if useTrail
        float newTrail = low + (atr * effTrail)
        trailSL := math.min(trailSL, newTrail)   // only moves down, never up
    trailSL := math.min(trailSL, lockSL)         // never above the locked profit floor
    slPrice := useTrail ? trailSL : lockSL       // trail off -> stop sits at the lock only

// --- TP/SL HIT CHECKS ---
// LONG exits
if activeTrade == "LONG"
    if not tp1Hit and high >= tp1Price
        tp1Hit  := true
        reachedTP1 += 1
        evtTP1 := true
        lockSL  := entryPrice + (atr * beBufferMult)        // lock breakeven (+buffer) — no more red
        trailSL := math.max(close - (atr * effTrail), lockSL)
        slPrice := useTrail ? trailSL : lockSL
        label.new(bar_index, high, "TP1 ✓\nBE LOCKED", color=color.new(color.green, 40), textcolor=color.white, style=label.style_label_down, size=size.tiny)

    if tp1Hit and not tp2Hit and high >= tp2Price
        tp2Hit  := true
        reachedTP2 += 1
        evtTP2 := true
        lockSL  := math.max(lockSL, tp1Price)               // ratchet floor up to TP1 profit
        trailSL := math.max(trailSL, lockSL)
        slPrice := useTrail ? trailSL : lockSL
        label.new(bar_index, high, "TP2 ✓\nTP1 LOCKED", color=color.new(color.green, 20), textcolor=color.white, style=label.style_label_down, size=size.tiny)

    if tp1Hit and tp2Hit and high >= tp3Price
        tradeWins += 1
        reachedTP3 += 1
        evtTP3 := true
        float rM = f_recordR(tp3Price, entryPrice, initRisk, true)
        totalR += rM
        rTrades += 1
        if rM >= 0
            grossWinR += rM
        else
            grossLossR += -rM
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false
        label.new(bar_index, high, "TP3 ✓\nFULL RUN!", color=color.green, textcolor=color.white, style=label.style_label_down, size=size.small)

    if low <= slPrice
        if tp1Hit
            tradeWins += 1       // trail/locked SL after TP1 -> WIN (>= breakeven)
        else
            tradeLosses += 1     // hit hard SL before TP1 -> LOSS
        evtSL := true
        float rM = f_recordR(slPrice, entryPrice, initRisk, true)
        totalR += rM
        rTrades += 1
        if rM >= 0
            grossWinR += rM
        else
            grossLossR += -rM
        string exitLabel = tp1Hit ? (tp2Hit ? "SL (after TP2)" : "SL (after TP1)") : "SL HIT"
        label.new(bar_index, low, exitLabel, color=color.red, textcolor=color.white, style=label.style_label_up, size=size.tiny)
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false

// SHORT exits
if activeTrade == "SHORT"
    if not tp1Hit and low <= tp1Price
        tp1Hit  := true
        reachedTP1 += 1
        evtTP1 := true
        lockSL  := entryPrice - (atr * beBufferMult)        // lock breakeven (+buffer) — no more red
        trailSL := math.min(close + (atr * effTrail), lockSL)
        slPrice := useTrail ? trailSL : lockSL
        label.new(bar_index, low, "TP1 ✓\nBE LOCKED", color=color.new(color.green, 40), textcolor=color.white, style=label.style_label_up, size=size.tiny)

    if tp1Hit and not tp2Hit and low <= tp2Price
        tp2Hit  := true
        reachedTP2 += 1
        evtTP2 := true
        lockSL  := math.min(lockSL, tp1Price)               // ratchet floor down to TP1 profit
        trailSL := math.min(trailSL, lockSL)
        slPrice := useTrail ? trailSL : lockSL
        label.new(bar_index, low, "TP2 ✓\nTP1 LOCKED", color=color.new(color.green, 20), textcolor=color.white, style=label.style_label_up, size=size.tiny)

    if tp1Hit and tp2Hit and low <= tp3Price
        tradeWins += 1
        reachedTP3 += 1
        evtTP3 := true
        float rM = f_recordR(tp3Price, entryPrice, initRisk, false)
        totalR += rM
        rTrades += 1
        if rM >= 0
            grossWinR += rM
        else
            grossLossR += -rM
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false
        label.new(bar_index, low, "TP3 ✓\nFULL RUN!", color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small)

    if high >= slPrice
        if tp1Hit
            tradeWins += 1       // trail/locked SL after TP1 -> WIN (>= breakeven)
        else
            tradeLosses += 1     // hit hard SL before TP1 -> LOSS
        evtSL := true
        float rM = f_recordR(slPrice, entryPrice, initRisk, false)
        totalR += rM
        rTrades += 1
        if rM >= 0
            grossWinR += rM
        else
            grossLossR += -rM
        string exitLabel = tp1Hit ? (tp2Hit ? "SL (after TP2)" : "SL (after TP1)") : "SL HIT"
        label.new(bar_index, high, exitLabel, color=color.red, textcolor=color.white, style=label.style_label_down, size=size.tiny)
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false

// --- PULLBACK RE-ENTRY ZONE (info only — does NOT change trade state) ---
// Flags when price retraces to the expected pullback level (between entry and SL)
// before TP1 is reached, so a position can be added on the dip.
if useReEntry and activeTrade == "LONG" and not tp1Hit and not reEntryTagged and low <= reEntryPrice and low > slPrice
    reEntryTagged := true
    evtReentry := true
    label.new(bar_index, low, "RE-ENTRY ➕\nAdd @ " + str.tostring(reEntryPrice, "#.##"), color=color.new(color.blue, 20), textcolor=color.white, style=label.style_label_up, size=size.tiny)

if useReEntry and activeTrade == "SHORT" and not tp1Hit and not reEntryTagged and high >= reEntryPrice and high < slPrice
    reEntryTagged := true
    evtReentry := true
    label.new(bar_index, high, "RE-ENTRY ➕\nAdd @ " + str.tostring(reEntryPrice, "#.##"), color=color.new(color.blue, 20), textcolor=color.white, style=label.style_label_down, size=size.tiny)

// --- NEAR-TP1 PROXIMITY RESET (only before TP1 hit) ---
if activeTrade == "LONG" and not tp1Hit
    float tpRange      = tp1Price - entryPrice
    float nearTPLevel  = entryPrice + (tpRange * tpProximity)
    bool touchedNearTP = ta.highest(high, 3) >= nearTPLevel
    bool reversedAway  = close < nearTPLevel
    if touchedNearTP and reversedAway
        // record this discretionary exit so the stats are complete
        float rM = f_recordR(close, entryPrice, initRisk, true)
        totalR += rM
        rTrades += 1
        if rM >= 0
            tradeWins += 1
            grossWinR += rM
        else
            tradeLosses += 1
            grossLossR += -rM
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false

if activeTrade == "SHORT" and not tp1Hit
    float tpRange      = entryPrice - tp1Price
    float nearTPLevel  = entryPrice - (tpRange * tpProximity)
    bool touchedNearTP = ta.lowest(low, 3) <= nearTPLevel
    bool reversedAway  = close > nearTPLevel
    if touchedNearTP and reversedAway
        // record this discretionary exit so the stats are complete
        float rM = f_recordR(close, entryPrice, initRisk, false)
        totalR += rM
        rTrades += 1
        if rM >= 0
            tradeWins += 1
            grossWinR += rM
        else
            tradeLosses += 1
            grossLossR += -rM
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false

// --- SESSION STATE ---
bool inAsia    = tradeAsia   and not na(time(timeframe.period, asiaSess,   sessTZ))
bool inLondon  = tradeLondon and not na(time(timeframe.period, londonSess, sessTZ))
bool inNY      = tradeNY     and not na(time(timeframe.period, nySess,     sessTZ))
bool sessionOK = (not useSessions) or inAsia or inLondon or inNY
string sessLabel = not useSessions ? "ALL" : (inLondon and inNY) ? "LDN+NY" : inLondon ? "LONDON" : inNY ? "NEW YORK" : inAsia ? "ASIA" : "OFF-HRS"

// --- SIGNALS ---
// Sideways guards: HTF trend alignment, real ADX trend, volatility expansion, active session
// On 5m & lower (scalp), drop the counter-trend filter so both directions can trigger.
// The sideways guard (not isSideways) in filtersOK still applies — so only ranging
// signals are blocked, not direction.
bool lowTF        = noCtFilterLowTF and baseMin <= 5
bool trendOKlong  = lowTF or (((not requireHTFTrend) or trend1h == "UPTREND")   and ((not require4H) or trend4h == "UPTREND"))
bool trendOKshort = lowTF or (((not requireHTFTrend) or trend1h == "DOWNTREND") and ((not require4H) or trend4h == "DOWNTREND"))
bool adxOK        = (not requireADXtrend) or (adxValue >= adxThreshold)
bool expansionOK  = (not requireExpansion) or (not atrCompressed)
bool filtersOK    = not isSideways and adxOK and expansionOK and sessionOK

// Pullback entry: price dips to the value EMA, then rejects with a confirmation
// candle in the trend direction (buy the dip / sell the rally). RSI confirms momentum.
bool pbLong   = low <= ema20  and close > ema20 and close > open and rsiValue > 50
bool pbShort  = high >= ema20 and close < ema20 and close < open and rsiValue < 50
// Original momentum entry (used when pullback mode is off)
bool momLong  = ta.crossover(rsiValue, 45)  and close > low[1]
bool momShort = ta.crossunder(rsiValue, 55) and close < high[1]

// Enhanced confirmation: the trigger candle must close strongly in the trade
// direction (top/bottom fraction of its range) AND RSI must be turning, not fading.
float barRange  = high - low
bool  strongUp  = (not strongConfirm) or (close >= high - barRange * closeFrac and rsiValue > rsiValue[1])
bool  strongDn  = (not strongConfirm) or (close <= low  + barRange * closeFrac and rsiValue < rsiValue[1])

// Momentum breakout: a strong expansion candle that breaks the recent range in the
// 1H trend direction. Needs only 1H (not 4H) and no pullback — catches fast moves
// (e.g. a massive volatile drop) that the pullback entry sits out.
bool brkLong  = momoEntry and close > ta.highest(high, brkLen)[1] and not atrCompressed and (lowTF or trend1h == "UPTREND")
bool brkShort = momoEntry and close < ta.lowest(low,  brkLen)[1]  and not atrCompressed and (lowTF or trend1h == "DOWNTREND")

// Base entry (pullback or original momentum) with full confluence + confirmation,
// OR a clean breakout (1H-only). Either path can trigger.
bool baseLong  = (pullbackMode ? pbLong  : momLong)  and trendOKlong  and strongUp
bool baseShort = (pullbackMode ? pbShort : momShort) and trendOKshort and strongDn

bool buySignal  = filtersOK and (baseLong  or brkLong)
bool sellSignal = filtersOK and (baseShort or brkShort)

// Optional no-repaint gate: only act once the bar has closed (live = chart)
bool barOK  = (not confirmOnClose) or barstate.isconfirmed
bool doBuy  = buySignal  and (activeTrade != "LONG")  and barOK
bool doSell = sellSignal and (activeTrade != "SHORT") and barOK

if doBuy
    // opposite-signal flip: the new buy closes any open short first, acting as a stop
    if activeTrade == "SHORT"
        if close <= entryPrice
            tradeWins += 1       // short closed in profit on the flip -> WIN
        else
            tradeLosses += 1     // short closed in loss on the flip -> LOSS
        float rM = f_recordR(close, entryPrice, initRisk, false)
        totalR += rM
        rTrades += 1
        if rM >= 0
            grossWinR += rM
        else
            grossLossR += -rM
        label.new(bar_index, high, "FLIP EXIT\n→ BUY", color=color.new(color.orange, 20), textcolor=color.white, style=label.style_label_down, size=size.tiny)
    activeTrade := "LONG"
    entryPrice  := close
    // --- Adaptive SL: protective swing low + auto ATR buffer, floored & capped by ATR ---
    float structSL  = swingLow - (atr * slBufferMult)
    float atrSL     = close - (atr * effSLmult)
    float rawSL     = useStructure ? math.min(structSL, atrSL) : atrSL
    // bound risk so R:R stays sane: never tighter than min, never wider than max
    rawSL := math.max(rawSL, close - (atr * maxSLMult))
    rawSL := math.min(rawSL, close - (atr * minSLMult))
    slPrice := rawSL
    float riskLong = entryPrice - slPrice
    initRisk := riskLong   // 1R for this trade (used by the expectancy tracker)
    // --- Adaptive TPs: scale to actual risk (auto R:R), snap runner to real structure ---
    tp1Price := useRRtps ? entryPrice + (riskLong * effRR1) : close + (atr * effTP1m)
    tp2Price := useRRtps ? entryPrice + (riskLong * effRR2) : close + (atr * effTP2m)
    tp3Price := useRRtps ? entryPrice + (riskLong * effRR3) : close + (atr * effTP3m)
    if useStructure and dynResist > tp1Price
        tp3Price := math.max(tp3Price, dynResist)   // target true structural resistance
    // --- Pullback re-entry level (between entry and SL) ---
    reEntryPrice := entryPrice - (riskLong * reEntryRatio)
    trailSL     := slPrice
    lockSL      := na
    tp1Hit      := false
    tp2Hit      := false
    reEntryTagged := false
    tradeConf   := (mainTrend == "UPTREND" ? 88 : 65)
    label.new(bar_index, low, "BUY\nEnt: " + str.tostring(entryPrice, "#.##") + "\nTP1: " + str.tostring(tp1Price, "#.##") + "\nTP2: " + str.tostring(tp2Price, "#.##") + "\nTP3: " + str.tostring(tp3Price, "#.##") + "\nSL: " + str.tostring(slPrice, "#.##") + "\nRe-Entry: " + str.tostring(reEntryPrice, "#.##"), color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small)

if doSell
    // opposite-signal flip: the new sell closes any open long first, acting as a stop
    if activeTrade == "LONG"
        if close >= entryPrice
            tradeWins += 1       // long closed in profit on the flip -> WIN
        else
            tradeLosses += 1     // long closed in loss on the flip -> LOSS
        float rM = f_recordR(close, entryPrice, initRisk, true)
        totalR += rM
        rTrades += 1
        if rM >= 0
            grossWinR += rM
        else
            grossLossR += -rM
        label.new(bar_index, low, "FLIP EXIT\n→ SELL", color=color.new(color.orange, 20), textcolor=color.white, style=label.style_label_up, size=size.tiny)
    activeTrade := "SHORT"
    entryPrice  := close
    // --- Adaptive SL: protective swing high + auto ATR buffer, floored & capped by ATR ---
    float structSL  = swingHigh + (atr * slBufferMult)
    float atrSL     = close + (atr * effSLmult)
    float rawSL     = useStructure ? math.max(structSL, atrSL) : atrSL
    rawSL := math.min(rawSL, close + (atr * maxSLMult))
    rawSL := math.max(rawSL, close + (atr * minSLMult))
    slPrice := rawSL
    float riskShort = slPrice - entryPrice
    initRisk := riskShort   // 1R for this trade (used by the expectancy tracker)
    tp1Price := useRRtps ? entryPrice - (riskShort * effRR1) : close - (atr * effTP1m)
    tp2Price := useRRtps ? entryPrice - (riskShort * effRR2) : close - (atr * effTP2m)
    tp3Price := useRRtps ? entryPrice - (riskShort * effRR3) : close - (atr * effTP3m)
    if useStructure and dynSupport < tp1Price
        tp3Price := math.min(tp3Price, dynSupport)   // target true structural support
    reEntryPrice := entryPrice + (riskShort * reEntryRatio)
    trailSL     := slPrice
    lockSL      := na
    tp1Hit      := false
    tp2Hit      := false
    reEntryTagged := false
    tradeConf   := (mainTrend == "DOWNTREND" ? 92 : 70)
    label.new(bar_index, high, "SELL\nEnt: " + str.tostring(entryPrice, "#.##") + "\nTP1: " + str.tostring(tp1Price, "#.##") + "\nTP2: " + str.tostring(tp2Price, "#.##") + "\nTP3: " + str.tostring(tp3Price, "#.##") + "\nSL: " + str.tostring(slPrice, "#.##") + "\nRe-Entry: " + str.tostring(reEntryPrice, "#.##"), color=color.red, textcolor=color.white, style=label.style_label_down, size=size.small)

// Stamp the most recent signal (time + bar) for the "LAST SIGNAL" readout
if doBuy or doSell
    lastSigBar  := bar_index
    lastSigTime := time
    lastSigDir  := doBuy ? "BUY" : "SELL"

// --- LAST-SIGNAL LEVEL LINES (only the most recent signal is shown) ---
bool showLevels = input.bool(true, "Show last-signal level lines", group="Visuals")

var line  lnEntry = na
var line  lnTP1   = na
var line  lnTP2   = na
var line  lnTP3   = na
var line  lnSL    = na
var line  lnTrail = na
var label lbEntry = na
var label lbTP1   = na
var label lbTP2   = na
var label lbTP3   = na
var label lbSL    = na
var label lbTrail = na

// On every fresh signal, wipe the previous signal's drawings and redraw the new set
if showLevels and (doBuy or doSell)
    line.delete(lnEntry), line.delete(lnTP1), line.delete(lnTP2), line.delete(lnTP3), line.delete(lnSL), line.delete(lnTrail)
    label.delete(lbEntry), label.delete(lbTP1), label.delete(lbTP2), label.delete(lbTP3), label.delete(lbSL), label.delete(lbTrail)
    lnTrail := na
    lbTrail := na
    lnEntry := line.new(bar_index, entryPrice, bar_index + 1, entryPrice, extend=extend.right, color=color.new(color.white, 0),  width=1, style=line.style_solid)
    lnTP1   := line.new(bar_index, tp1Price,   bar_index + 1, tp1Price,   extend=extend.right, color=color.new(color.green, 0),  width=1, style=line.style_dashed)
    lnTP2   := line.new(bar_index, tp2Price,   bar_index + 1, tp2Price,   extend=extend.right, color=color.new(color.green, 25), width=1, style=line.style_dashed)
    lnTP3   := line.new(bar_index, tp3Price,   bar_index + 1, tp3Price,   extend=extend.right, color=color.new(color.aqua, 0),   width=1, style=line.style_dashed)
    lnSL    := line.new(bar_index, slPrice,    bar_index + 1, slPrice,    extend=extend.right, color=color.new(color.red, 0),    width=1, style=line.style_dashed)
    lbEntry := label.new(bar_index, entryPrice, "ENTRY " + str.tostring(entryPrice, "#.##"), style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.white,  size=size.small)
    lbTP1   := label.new(bar_index, tp1Price,   "TP1 "   + str.tostring(tp1Price,   "#.##"), style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.green,  size=size.small)
    lbTP2   := label.new(bar_index, tp2Price,   "TP2 "   + str.tostring(tp2Price,   "#.##"), style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.green,  size=size.small)
    lbTP3   := label.new(bar_index, tp3Price,   "TP3 "   + str.tostring(tp3Price,   "#.##"), style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.aqua,   size=size.small)
    lbSL    := label.new(bar_index, slPrice,    "SL "    + str.tostring(slPrice,    "#.##"), style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.red,    size=size.small)

// Trail line — appears only once the trail is activated (after TP1), updates each bar
if showLevels and activeTrade != "NONE" and tp1Hit
    if na(lnTrail)
        lnTrail := line.new(bar_index, slPrice, bar_index + 1, slPrice, extend=extend.right, color=color.new(color.orange, 0), width=2, style=line.style_solid)
        lbTrail := label.new(bar_index, slPrice, "TRAIL " + str.tostring(slPrice, "#.##"), style=label.style_label_left, color=color.new(color.black, 100), textcolor=color.orange, size=size.small)
    else
        line.set_y1(lnTrail, slPrice), line.set_y2(lnTrail, slPrice)
        label.set_y(lbTrail, slPrice), label.set_text(lbTrail, "TRAIL " + str.tostring(slPrice, "#.##"))

// Keep all price tags pinned to the right edge (current bar)
if showLevels and not na(lnEntry)
    label.set_x(lbEntry, bar_index), label.set_x(lbTP1, bar_index), label.set_x(lbTP2, bar_index), label.set_x(lbTP3, bar_index), label.set_x(lbSL, bar_index)
    if not na(lbTrail)
        label.set_x(lbTrail, bar_index)

// --- SIDEWAYS BACKGROUND ---
bgcolor(isSideways ? color.new(color.yellow, 90) : na, title="Ranging Zone")

// --- OFF-SESSION BACKGROUND ---
bgcolor((useSessions and not sessionOK) ? color.new(color.gray, 88) : na, title="Off-Session (no signals)")

// --- DASHBOARD ---
string tpStage = not tp1Hit ? "Targeting TP1" : not tp2Hit ? "TP1 ✓ → TP2" : "TP2 ✓ → TP3 🚀"
color stageColor = not tp1Hit ? color.white : not tp2Hit ? color.lime : color.aqua

var table hub = table.new(position.bottom_left, 4, 13, bgcolor=color.rgb(15, 15, 15), border_color=color.gray, border_width=1)

if barstate.islast
    table.cell(hub, 0, 0, "MIGO SNIPER V6", text_color=color.white, bgcolor=color.rgb(65, 14, 58))
    table.merge_cells(hub, 0, 0, 3, 0)

    string arrow1h      = trend1h == "UPTREND" ? "▲" : trend1h == "DOWNTREND" ? "▼" : "–"
    string arrow4h      = trend4h == "UPTREND" ? "▲" : trend4h == "DOWNTREND" ? "▼" : "–"
    bool   htfAligned   = trend1h == trend4h and trend1h != "SIDEWAYS"
    string mktState     = isSideways ? "⚠ RANGING — WAIT" : lbl1 + " " + arrow1h + "   " + lbl2 + " " + arrow4h + (htfAligned ? "  ✓" : "  ✗")
    color mktStateColor = isSideways ? color.yellow : not htfAligned ? color.orange : trend1h == "UPTREND" ? color.green : color.red
    table.cell(hub, 0, 1, "MKT STATE", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 1, mktState, text_color=mktStateColor)
    table.merge_cells(hub, 1, 1, 3, 1)

    int   totalRes = tradeWins + tradeLosses
    float winRate  = totalRes > 0 ? 100.0 * tradeWins / totalRes : na
    string wrText  = totalRes > 0 ? str.tostring(math.round(winRate)) + "% (" + str.tostring(tradeWins) + "/" + str.tostring(totalRes) + ")" : "-"
    color  wrColor = na(winRate) ? color.gray : winRate >= 50 ? color.green : color.red
    table.cell(hub, 0, 2, "CONFIDENCE", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 2, isSideways ? "-" : str.tostring(tradeConf) + "%", text_color=color.yellow)
    table.cell(hub, 2, 2, "WIN RATE",   text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 2, wrText, text_color=wrColor)

    table.cell(hub, 0, 3, "SIGNAL", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 3, isSideways ? "BLOCKED" : activeTrade, text_color=isSideways ? color.yellow : activeTrade == "LONG" ? color.green : activeTrade == "SHORT" ? color.red : color.yellow)
    table.cell(hub, 2, 3, "STAGE",   text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 3, activeTrade != "NONE" ? tpStage : "-", text_color=stageColor)

    table.cell(hub, 0, 4, "ENTRY",   text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 4, activeTrade != "NONE" ? str.tostring(entryPrice, "#.##") : "WAIT", text_color=color.white)
    table.cell(hub, 2, 4, "TRAIL SL", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 4, (activeTrade != "NONE" and tp1Hit) ? str.tostring(slPrice, "#.##") : "-", text_color=color.orange)

    table.cell(hub, 0, 5, "TP1", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 5, activeTrade != "NONE" ? str.tostring(tp1Price, "#.##") : "-", text_color=tp1Hit ? color.lime : color.green)
    table.cell(hub, 2, 5, "SL",  text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 5, activeTrade != "NONE" ? str.tostring(slPrice, "#.##") : "-", text_color=color.red)

    table.cell(hub, 0, 6, "TP2", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 6, activeTrade != "NONE" ? str.tostring(tp2Price, "#.##") : "-", text_color=tp2Hit ? color.lime : color.green)
    table.cell(hub, 2, 6, "TP3 🚀", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 6, activeTrade != "NONE" ? str.tostring(tp3Price, "#.##") : "-", text_color=color.aqua)

    table.cell(hub, 0, 7, "RE-ENTRY ➕", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 7, (activeTrade != "NONE" and useReEntry) ? str.tostring(reEntryPrice, "#.##") + (reEntryTagged ? " ✓" : "") : "-", text_color=reEntryTagged ? color.aqua : color.new(color.blue, 0))
    table.cell(hub, 2, 7, "RISK (R)", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 7, activeTrade != "NONE" ? str.tostring(math.abs(entryPrice - slPrice), "#.##") : "-", text_color=color.orange)

    float volRatio   = atr / atrSma
    string volStatus = volRatio > 1.5 ? "HIGH VOL" : volRatio < 0.7 ? "LOW VOL" : "STABLE"
    color volColor   = volStatus == "HIGH VOL" ? color.red : volStatus == "LOW VOL" ? color.aqua : color.green
    bool sessActive = (not useSessions) or sessionOK
    color sessColor = not useSessions ? color.gray : sessionOK ? color.green : color.red
    table.cell(hub, 0, 8, "MKT IMPACT", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 8, volStatus, text_color=volColor)
    table.cell(hub, 2, 8, "SESSION", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 8, sessLabel + (sessActive ? "" : " ⛔"), text_color=sessColor)

    string autoInfo = autoAdaptive ? "  AUTO: vol×" + str.tostring(volFactor, "#.##") + " trend×" + str.tostring(trendStr, "#.##") : "  AUTO: OFF"
    string adxInfo = "ADX: " + str.tostring(math.round(adxValue, 1)) + (adxFlat ? " ✗" : " ✓") + "  ATR: " + (atrCompressed ? "✗" : "✓") + "  EMA: " + (emaTooClose ? "✗" : "✓") + autoInfo
    table.cell(hub, 0, 9, adxInfo, text_color=color.new(color.gray, 30), text_size=size.small)
    table.merge_cells(hub, 0, 9, 3, 9)

    int    trailAfterTP1 = reachedTP1 - reachedTP2   // tagged TP1 but trailed out before TP2
    int    trailAfterTP2 = reachedTP2 - reachedTP3   // tagged TP2 but trailed out before TP3
    string tpReach = "REACHED  TP1:" + str.tostring(reachedTP1) + "  →TP2:" + str.tostring(reachedTP2) + "  →TP3:" + str.tostring(reachedTP3) + "   | trail-out aTP1:" + str.tostring(trailAfterTP1) + "  aTP2:" + str.tostring(trailAfterTP2)
    table.cell(hub, 0, 10, tpReach, text_color=color.new(color.aqua, 10), text_size=size.small)
    table.merge_cells(hub, 0, 10, 3, 10)

    float  avgR  = rTrades > 0 ? totalR / rTrades : na
    float  pf    = grossLossR > 0 ? grossWinR / grossLossR : na
    color  expCol = na(avgR) ? color.gray : avgR > 0 ? color.green : color.red
    string expTxt = rTrades > 0 ? "EXPECTANCY  avgR:" + str.tostring(avgR, "#.##") + "R   totalR:" + str.tostring(totalR, "#.#") + "R   PF:" + (na(pf) ? "∞" : str.tostring(pf, "#.##")) + "   (" + str.tostring(rTrades) + " trades)" : "EXPECTANCY  — no closed trades yet"
    table.cell(hub, 0, 11, expTxt, text_color=expCol, text_size=size.small)
    table.merge_cells(hub, 0, 11, 3, 11)

    float  msSince  = na(lastSigTime) ? na : timenow - lastSigTime
    int    barsAgo  = na(lastSigBar) ? na : bar_index - lastSigBar
    string ago = na(msSince) ? "no signals in view" : msSince >= 86400000 ? str.tostring(math.floor(msSince / 86400000)) + "d " + str.tostring(math.floor((msSince % 86400000) / 3600000)) + "h ago" : msSince >= 3600000 ? str.tostring(math.floor(msSince / 3600000)) + "h " + str.tostring(math.floor((msSince % 3600000) / 60000)) + "m ago" : str.tostring(math.floor(msSince / 60000)) + "m ago"
    string lastTxt = na(lastSigTime) ? "LAST SIGNAL  — none in loaded history" : "LAST SIGNAL  " + lastSigDir + "  " + ago + "  (" + str.tostring(barsAgo) + " bars)"
    color  lastCol = na(lastSigTime) ? color.gray : lastSigDir == "BUY" ? color.lime : color.orange
    table.cell(hub, 0, 12, lastTxt, text_color=lastCol, text_size=size.small)
    table.merge_cells(hub, 0, 12, 3, 12)

// --- VISUALS ---
plot(maLong, color=color.new(color.green, 50), title="200 EMA")
plot(maShort, color=color.new(#0d64ac, 50), title="50 EMA")
plot(pullbackMode ? ema20 : na, color=color.new(color.yellow, 30), title="Pullback Value EMA")

// Trail SL line while active
plot(activeTrade != "NONE" and tp1Hit ? slPrice : na, color=color.orange, style=plot.style_stepline, linewidth=2, title="Trail Stop")

// Pullback re-entry level while active (before TP1)
plot((useReEntry and activeTrade != "NONE" and not tp1Hit) ? reEntryPrice : na, color=color.new(color.blue, 0), style=plot.style_stepline, linewidth=1, title="Re-Entry Level")

// --- ALERTS (create one alert per event in TradingView's Add Alert dialog) ---
alertcondition(doBuy,      title="BUY signal",      message="MIGO {{ticker}} {{interval}}: BUY @ {{close}}")
alertcondition(doSell,     title="SELL signal",     message="MIGO {{ticker}} {{interval}}: SELL @ {{close}}")
alertcondition(doBuy or doSell, title="Any entry (BUY or SELL)", message="MIGO {{ticker}} {{interval}}: new entry @ {{close}}")
alertcondition(evtTP1,     title="TP1 hit",         message="MIGO {{ticker}} {{interval}}: TP1 hit — breakeven locked")
alertcondition(evtTP2,     title="TP2 hit",         message="MIGO {{ticker}} {{interval}}: TP2 hit — TP1 profit locked")
alertcondition(evtTP3,     title="TP3 hit",         message="MIGO {{ticker}} {{interval}}: TP3 hit — full run")
alertcondition(evtSL,      title="Stop hit",        message="MIGO {{ticker}} {{interval}}: stop hit")
alertcondition(evtReentry, title="Re-entry zone",   message="MIGO {{ticker}} {{interval}}: price at re-entry add level")
