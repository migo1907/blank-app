# ── GitHub (replaces Supabase — free, no account needed beyond your repo) ─────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx   # Personal Access Token (repo scope)
GITHUB_REPO=migo1907/blank-app          # your repo: username/repo-name
GITHUB_BRANCH=data                      # branch where JSON data files are stored

# ── Anthropic (Claude for news sentiment) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── NewsAPI.org (free tier: 100 req/day) ──────────────────────────────────────
NEWSAPI_KEY=your_newsapi_key_here

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AABBcc...
TELEGRAM_CHAT_ID=-100xxxxxxxxxx         # your channel/group chat ID

# ── Webhook security ──────────────────────────────────────────────────────────
WEBHOOK_SECRET=choose_a_random_secret_string

# ── App settings ──────────────────────────────────────────────────────────────
PORT=8000
SIGNAL_INTERVAL_MINUTES=15
