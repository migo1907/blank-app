# DAMAN Platform — environment template
# Copy this file to `.env` and fill in real values. NEVER commit your real .env.
# (Only VITE_* vars are exposed to the browser; keep truly secret keys server-side.)

# --- Supabase (required) ---
# Project URL + anon key from your Supabase project settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Alpaca Markets (market data) ---
# https://alpaca.markets/  (free IEX real-time data)
VITE_ALPACA_API_KEY=
VITE_ALPACA_SECRET_KEY=

# --- Google Gemini (AI market commentary) ---
# https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=

# --- Polygon.io (optional market data) ---
# https://polygon.io/
VITE_POLYGON_API_KEY=

# NOTE: Server-side keys used by Supabase Edge Functions (e.g. TRADIER_API_TOKEN,
# ALPACA_API_KEY/SECRET, POLYGON_API_KEY) are configured as Supabase function
# secrets, not here. See the *_SETUP_GUIDE.md docs.
