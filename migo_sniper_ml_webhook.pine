//@version=6
indicator("XAU/USD Migo VS Market Sniper Pro [ML + Adaptive + Cloud]", overlay=true, max_labels_count=500, max_bars_back=5000)

// ═══════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════
int   lookback      = input.int(50,    "Structural Lookback",        group="⚙️ Trade")
float atrMultTP1    = input.float(1.5, "TP1 ATR Multiplier",         group="⚙️ Trade")
float atrMultTP2    = input.float(2.5, "TP2 ATR Multiplier",         group="⚙️ Trade")
float atrMultTP3    = input.float(4.0, "TP3 ATR Multiplier Runner",  group="⚙️ Trade")
float atrMultSL     = input.float(1.5, "SL ATR Multiplier",          group="⚙️ Trade")
float trailMult     = input.float(1.2, "Trail Stop Multiplier",      group="⚙️ Trade")
float tpProximity   = input.float(80.0,"Near-TP Reset %",            group="⚙️ Trade", minval=50, maxval=99) / 100.0
int   adxLen        = input.int(14,    "ADX Length",                 group="🔎 Filters")
float adxThreshold  = input.float(20.0,"ADX Sideways Threshold",     group="🔎 Filters")
float atrRangeRatio = input.float(0.75,"ATR Range Ratio",            group="🔎 Filters")
float emaBandPct    = input.float(0.3, "EMA Band %",                 group="🔎 Filters")
int   mlK           = input.int(8,     "K Neighbors",                group="🤖 KNN", minval=3, maxval=20)
int   mlDepth       = input.int(2000,  "History Depth",              group="🤖 KNN", minval=500, maxval=5000)
int   mlLag         = input.int(4,     "Forward Lag",                group="🤖 KNN", minval=1, maxval=20)
float mlMinScore    = input.float(0.55,"Min Score",                  group="🤖 KNN", minval=0.50, maxval=0.90, step=0.05)
float learnRate     = input.float(0.05,"Learning Rate",              group="🧠 Adaptive", minval=0.01, maxval=0.30, step=0.01)
float winReward     = input.float(0.15,"Win Reward",                 group="🧠 Adaptive", minval=0.05, maxval=0.50, step=0.05)
float lossPenalty   = input.float(0.20,"Loss Penalty",               group="🧠 Adaptive", minval=0.05, maxval=0.50, step=0.05)
bool  useKernel     = input.bool(true, "Kernel Regression",          group="📈 Kernel")
int   kWin          = input.int(8,     "Kernel Window",              group="📈 Kernel", minval=3, maxval=50)
float kH            = input.float(8.0, "Bandwidth h",                group="📈 Kernel", minval=1.0, maxval=50.0)
float kAlpha        = input.float(1.0, "Alpha",                      group="📈 Kernel", minval=0.1, maxval=5.0)
// ── Cloud backend (Level 2) ─────────────────────────────────────────────────
string webhookSecret = input.string("your_secret_here", "Webhook Secret", group="☁️ Cloud Backend")

// ═══════════════════════════════════════════════════════
// INDICATORS
// ═══════════════════════════════════════════════════════
float rsiVal    = ta.rsi(close, 14)
float maLong    = ta.ema(close, 200)
float maShort   = ta.ema(close, 50)
float atr       = ta.atr(14)
float atrSma    = ta.sma(atr, 20)
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
float macdLine  = ta.ema(close, 12) - ta.ema(close, 26)
float macdHist  = macdLine - ta.ema(macdLine, 9)
[bbUp, bbMid, bbLow_] = ta.bb(close, 20, 2.0)
float bbPct     = (close - bbLow_) / math.max(bbUp - bbLow_, 0.0001)
float willR     = ta.wpr(14)
float cmo       = ta.cmo(close, 14) / 100.0
float ma50_1h   = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
float rsi_1h    = request.security(syminfo.tickerid, "60", ta.rsi(close, 14))
string mainTrend = close > ma50_1h and rsi_1h > 50 ? "UPTREND" : close < ma50_1h and rsi_1h < 50 ? "DOWNTREND" : "SIDEWAYS"
bool adxFlat       = adxVal < adxThreshold
bool atrCompressed = atr < atrSma * atrRangeRatio
bool emaTooClose   = math.abs(maShort - maLong) / maLong * 100.0 < emaBandPct
bool isSideways    = (adxFlat ? 1 : 0) + (atrCompressed ? 1 : 0) + (emaTooClose ? 1 : 0) >= 2

// ═══════════════════════════════════════════════════════
// 8 FEATURES (normalized to [-1, +1])
// ═══════════════════════════════════════════════════════
float f1 = (rsiVal - 50.0) / 50.0
float f2 = math.min(adxVal / 50.0, 1.0) * (diPlus > diMinus ? 1.0 : -1.0)
float f3 = math.max(-1.0, math.min(1.0, (atr / atrSma - 1.0) * 2.0))
float f4 = math.max(-1.0, math.min(1.0, (bbPct - 0.5) * 2.0))
float f5 = math.max(-1.0, math.min(1.0, macdHist / math.max(atr * 0.1, 0.0001)))
float f6 = -(willR + 50.0) / 50.0
float f7 = cmo
float f8 = math.max(-1.0, math.min(1.0, (close - maLong) / (atr * 5.0)))

// ═══════════════════════════════════════════════════════
// ADAPTIVE WEIGHTS (in-session, mirrors cloud weights)
// ═══════════════════════════════════════════════════════
var float w1 = 1.0
var float w2 = 1.0
var float w3 = 1.0
var float w4 = 1.0
var float w5 = 1.0
var float w6 = 1.0
var float w7 = 1.0
var float w8 = 1.0
var int totalWins   = 0
var int totalLosses = 0
var float ef1 = 0.0
var float ef2 = 0.0
var float ef3 = 0.0
var float ef4 = 0.0
var float ef5 = 0.0
var float ef6 = 0.0
var float ef7 = 0.0
var float ef8 = 0.0

// ═══════════════════════════════════════════════════════
// HELPER FUNCTIONS
// ═══════════════════════════════════════════════════════
clampW(w) => math.max(0.2, math.min(3.0, w))

wLorDist(a1, a2, a3, a4, a5, a6, a7, a8, b1, b2, b3, b4, b5, b6, b7, b8, _w1, _w2, _w3, _w4, _w5, _w6, _w7, _w8) =>
    float _d = _w1 * math.log(1.0 + math.abs(a1 - b1))
    _d += _w2 * math.log(1.0 + math.abs(a2 - b2))
    _d += _w3 * math.log(1.0 + math.abs(a3 - b3))
    _d += _w4 * math.log(1.0 + math.abs(a4 - b4))
    _d += _w5 * math.log(1.0 + math.abs(a5 - b5))
    _d += _w6 * math.log(1.0 + math.abs(a6 - b6))
    _d += _w7 * math.log(1.0 + math.abs(a7 - b7))
    _d += _w8 * math.log(1.0 + math.abs(a8 - b8))
    _d

rqKernel(src, h, alpha, window) =>
    float num = 0.0
    float den = 0.0
    for i = 0 to window - 1
        float wk = math.pow(1.0 + float(i * i) / (2.0 * alpha * h * h), -alpha)
        num += src[i] * wk
        den += wk
    den > 0.0 ? num / den : src[0]

// ═══════════════════════════════════════════════════════
// KNN CLASSIFIER
// ═══════════════════════════════════════════════════════
var float mlBull = 0.5
var float mlBear = 0.5

if bar_index > mlK * 2 + mlLag
    float[] kDist = array.new_float(mlK, 1.0e10)
    int[]   kLbl  = array.new_int(mlK, 0)
    int searchLen = math.min(mlDepth, bar_index - mlLag - 1)
    int step      = math.max(1, math.round(float(searchLen) / 400.0))
    for i = mlLag + step to searchLen by step
        if not na(f1[i]) and not na(f2[i])
            float d = wLorDist(f1, f2, f3, f4, f5, f6, f7, f8, f1[i], f2[i], f3[i], f4[i], f5[i], f6[i], f7[i], f8[i], w1, w2, w3, w4, w5, w6, w7, w8)
            int   farIdx  = 0
            float farDist = array.get(kDist, 0)
            for j = 1 to mlK - 1
                float kd = array.get(kDist, j)
                if kd > farDist
                    farDist := kd
                    farIdx  := j
            if d < farDist
                array.set(kDist, farIdx, d)
                int lbl = close[i - mlLag] > close[i] ? 1 : -1
                array.set(kLbl, farIdx, lbl)
    int bulls = 0
    int bears = 0
    for j = 0 to mlK - 1
        if array.get(kDist, j) < 1.0e9
            if array.get(kLbl, j) == 1
                bulls += 1
            else
                bears += 1
    int total = bulls + bears
    mlBull := total > 0 ? float(bulls) / float(total) : 0.5
    mlBear := total > 0 ? float(bears) / float(total) : 0.5

bool mlBullish = mlBull >= mlMinScore
bool mlBearish = mlBear >= mlMinScore

// ═══════════════════════════════════════════════════════
// KERNEL REGRESSION
// ═══════════════════════════════════════════════════════
float kernelEst  = useKernel ? rqKernel(close, kH, kAlpha, kWin) : maShort
bool  kernelUp   = kernelEst > kernelEst[2]
bool  kernelDown = kernelEst < kernelEst[2]

// ═══════════════════════════════════════════════════════
// TRADE STATE
// ═══════════════════════════════════════════════════════
var string activeTrade = "NONE"
var float  entryPrice  = 0.0
var float  tp1Price    = 0.0
var float  tp2Price    = 0.0
var float  tp3Price    = 0.0
var float  slPrice     = 0.0
var int    tradeConf   = 0
var bool   tp1Hit      = false
var bool   tp2Hit      = false
var float  trailSL     = 0.0

// ═══════════════════════════════════════════════════════
// WEBHOOK PAYLOAD BUILDER
// ═══════════════════════════════════════════════════════
buildPayload(dir, outcome, stage, entPx, exitPx, mlSc) =>
    '{"secret":"' + webhookSecret + '"' +
    ',"trade_id":"' + syminfo.tickerid + '_' + str.tostring(timenow) + '"' +
    ',"direction":"' + dir + '"' +
    ',"outcome":"' + outcome + '"' +
    ',"tp_stage":"' + stage + '"' +
    ',"entry_price":' + str.tostring(entPx, "#.####") +
    ',"exit_price":' + str.tostring(exitPx, "#.####") +
    ',"ml_score":' + str.tostring(mlSc, "#.####") +
    ',"f1":' + str.tostring(ef1, "#.####") +
    ',"f2":' + str.tostring(ef2, "#.####") +
    ',"f3":' + str.tostring(ef3, "#.####") +
    ',"f4":' + str.tostring(ef4, "#.####") +
    ',"f5":' + str.tostring(ef5, "#.####") +
    ',"f6":' + str.tostring(ef6, "#.####") +
    ',"f7":' + str.tostring(ef7, "#.####") +
    ',"f8":' + str.tostring(ef8, "#.####") + '}'

// ═══════════════════════════════════════════════════════
// TRAIL STOP
// ═══════════════════════════════════════════════════════
if activeTrade == "LONG" and tp1Hit
    trailSL := math.max(trailSL, high - atr * trailMult)
    slPrice  := trailSL

if activeTrade == "SHORT" and tp1Hit
    trailSL := math.min(trailSL, low + atr * trailMult)
    slPrice  := trailSL

// ═══════════════════════════════════════════════════════
// LONG EXITS + ADAPTIVE UPDATE + WEBHOOK
// ═══════════════════════════════════════════════════════
if activeTrade == "LONG"
    if not tp1Hit and high >= tp1Price
        tp1Hit  := true
        trailSL := close - atr * trailMult
        slPrice := trailSL
        label.new(bar_index, high, "TP1 ✓\nTrail ON", color=color.new(color.green, 40), textcolor=color.white, style=label.style_label_down, size=size.tiny)

    if tp1Hit and not tp2Hit and high >= tp2Price
        tp2Hit := true
        label.new(bar_index, high, "TP2 ✓", color=color.new(color.green, 20), textcolor=color.white, style=label.style_label_down, size=size.tiny)

    if tp1Hit and tp2Hit and high >= tp3Price
        totalWins += 1
        w1 := clampW(w1 + learnRate * (ef1 >= 0.0 ? 1.0 : -1.0) * winReward)
        w2 := clampW(w2 + learnRate * (ef2 >= 0.0 ? 1.0 : -1.0) * winReward)
        w3 := clampW(w3 + learnRate * (ef3 >= 0.0 ? 1.0 : -1.0) * winReward)
        w4 := clampW(w4 + learnRate * (ef4 >= 0.0 ? 1.0 : -1.0) * winReward)
        w5 := clampW(w5 + learnRate * (ef5 >= 0.0 ? 1.0 : -1.0) * winReward)
        w6 := clampW(w6 + learnRate * (ef6 >= 0.0 ? 1.0 : -1.0) * winReward)
        w7 := clampW(w7 + learnRate * (ef7 >= 0.0 ? 1.0 : -1.0) * winReward)
        w8 := clampW(w8 + learnRate * (ef8 >= 0.0 ? 1.0 : -1.0) * winReward)
        alert(buildPayload(activeTrade, "WIN", "TP3", entryPrice, high, mlBull), alert.freq_once_per_bar_close)
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false
        label.new(bar_index, high, "TP3 ✓\nFULL RUN! ☁️", color=color.green, textcolor=color.white, style=label.style_label_down, size=size.small)

    if low <= slPrice
        string exitLabel = tp1Hit ? (tp2Hit ? "SL (after TP2)" : "SL (after TP1)") : "SL HIT"
        string outcome   = tp1Hit ? "PARTIAL" : "LOSS"
        string stage     = tp2Hit ? "SL_TP2" : (tp1Hit ? "SL_TP1" : "SL")
        if not tp1Hit
            totalLosses += 1
            w1 := clampW(w1 - learnRate * (ef1 >= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w2 := clampW(w2 - learnRate * (ef2 >= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w3 := clampW(w3 - learnRate * (ef3 >= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w4 := clampW(w4 - learnRate * (ef4 >= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w5 := clampW(w5 - learnRate * (ef5 >= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w6 := clampW(w6 - learnRate * (ef6 >= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w7 := clampW(w7 - learnRate * (ef7 >= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w8 := clampW(w8 - learnRate * (ef8 >= 0.0 ? 1.0 : -1.0) * lossPenalty)
        else
            totalWins += 1
            float pr = winReward * 0.4
            w1 := clampW(w1 + learnRate * (ef1 >= 0.0 ? 1.0 : -1.0) * pr)
            w2 := clampW(w2 + learnRate * (ef2 >= 0.0 ? 1.0 : -1.0) * pr)
            w3 := clampW(w3 + learnRate * (ef3 >= 0.0 ? 1.0 : -1.0) * pr)
            w4 := clampW(w4 + learnRate * (ef4 >= 0.0 ? 1.0 : -1.0) * pr)
            w5 := clampW(w5 + learnRate * (ef5 >= 0.0 ? 1.0 : -1.0) * pr)
            w6 := clampW(w6 + learnRate * (ef6 >= 0.0 ? 1.0 : -1.0) * pr)
            w7 := clampW(w7 + learnRate * (ef7 >= 0.0 ? 1.0 : -1.0) * pr)
            w8 := clampW(w8 + learnRate * (ef8 >= 0.0 ? 1.0 : -1.0) * pr)
        alert(buildPayload(activeTrade, outcome, stage, entryPrice, low, mlBull), alert.freq_once_per_bar_close)
        label.new(bar_index, low, exitLabel + " ☁️", color=color.red, textcolor=color.white, style=label.style_label_up, size=size.tiny)
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false

// ═══════════════════════════════════════════════════════
// SHORT EXITS + ADAPTIVE UPDATE + WEBHOOK
// ═══════════════════════════════════════════════════════
if activeTrade == "SHORT"
    if not tp1Hit and low <= tp1Price
        tp1Hit  := true
        trailSL := close + atr * trailMult
        slPrice := trailSL
        label.new(bar_index, low, "TP1 ✓\nTrail ON", color=color.new(color.green, 40), textcolor=color.white, style=label.style_label_up, size=size.tiny)

    if tp1Hit and not tp2Hit and low <= tp2Price
        tp2Hit := true
        label.new(bar_index, low, "TP2 ✓", color=color.new(color.green, 20), textcolor=color.white, style=label.style_label_up, size=size.tiny)

    if tp1Hit and tp2Hit and low <= tp3Price
        totalWins += 1
        w1 := clampW(w1 + learnRate * (ef1 <= 0.0 ? 1.0 : -1.0) * winReward)
        w2 := clampW(w2 + learnRate * (ef2 <= 0.0 ? 1.0 : -1.0) * winReward)
        w3 := clampW(w3 + learnRate * (ef3 <= 0.0 ? 1.0 : -1.0) * winReward)
        w4 := clampW(w4 + learnRate * (ef4 <= 0.0 ? 1.0 : -1.0) * winReward)
        w5 := clampW(w5 + learnRate * (ef5 <= 0.0 ? 1.0 : -1.0) * winReward)
        w6 := clampW(w6 + learnRate * (ef6 <= 0.0 ? 1.0 : -1.0) * winReward)
        w7 := clampW(w7 + learnRate * (ef7 <= 0.0 ? 1.0 : -1.0) * winReward)
        w8 := clampW(w8 + learnRate * (ef8 <= 0.0 ? 1.0 : -1.0) * winReward)
        alert(buildPayload(activeTrade, "WIN", "TP3", entryPrice, low, mlBear), alert.freq_once_per_bar_close)
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false
        label.new(bar_index, low, "TP3 ✓\nFULL RUN! ☁️", color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small)

    if high >= slPrice
        string exitLabel = tp1Hit ? (tp2Hit ? "SL (after TP2)" : "SL (after TP1)") : "SL HIT"
        string outcome   = tp1Hit ? "PARTIAL" : "LOSS"
        string stage     = tp2Hit ? "SL_TP2" : (tp1Hit ? "SL_TP1" : "SL")
        if not tp1Hit
            totalLosses += 1
            w1 := clampW(w1 - learnRate * (ef1 <= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w2 := clampW(w2 - learnRate * (ef2 <= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w3 := clampW(w3 - learnRate * (ef3 <= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w4 := clampW(w4 - learnRate * (ef4 <= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w5 := clampW(w5 - learnRate * (ef5 <= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w6 := clampW(w6 - learnRate * (ef6 <= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w7 := clampW(w7 - learnRate * (ef7 <= 0.0 ? 1.0 : -1.0) * lossPenalty)
            w8 := clampW(w8 - learnRate * (ef8 <= 0.0 ? 1.0 : -1.0) * lossPenalty)
        else
            totalWins += 1
            float pr = winReward * 0.4
            w1 := clampW(w1 + learnRate * (ef1 <= 0.0 ? 1.0 : -1.0) * pr)
            w2 := clampW(w2 + learnRate * (ef2 <= 0.0 ? 1.0 : -1.0) * pr)
            w3 := clampW(w3 + learnRate * (ef3 <= 0.0 ? 1.0 : -1.0) * pr)
            w4 := clampW(w4 + learnRate * (ef4 <= 0.0 ? 1.0 : -1.0) * pr)
            w5 := clampW(w5 + learnRate * (ef5 <= 0.0 ? 1.0 : -1.0) * pr)
            w6 := clampW(w6 + learnRate * (ef6 <= 0.0 ? 1.0 : -1.0) * pr)
            w7 := clampW(w7 + learnRate * (ef7 <= 0.0 ? 1.0 : -1.0) * pr)
            w8 := clampW(w8 + learnRate * (ef8 <= 0.0 ? 1.0 : -1.0) * pr)
        alert(buildPayload(activeTrade, outcome, stage, entryPrice, high, mlBear), alert.freq_once_per_bar_close)
        label.new(bar_index, high, exitLabel + " ☁️", color=color.red, textcolor=color.white, style=label.style_label_down, size=size.tiny)
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false

// ═══════════════════════════════════════════════════════
// GLOBAL SERIES (CW10002 / CW10003)
// ═══════════════════════════════════════════════════════
float highest3     = ta.highest(high, 3)
float lowest3      = ta.lowest(low, 3)
bool  rsiBullCross = ta.crossover(rsiVal, 45)
bool  rsiBearCross = ta.crossunder(rsiVal, 55)

// ═══════════════════════════════════════════════════════
// NEAR-TP1 PROXIMITY RESET
// ═══════════════════════════════════════════════════════
if activeTrade == "LONG" and not tp1Hit
    float tpRange     = tp1Price - entryPrice
    float nearTPLevel = entryPrice + tpRange * tpProximity
    if highest3 >= nearTPLevel and close < nearTPLevel
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false

if activeTrade == "SHORT" and not tp1Hit
    float tpRange     = entryPrice - tp1Price
    float nearTPLevel = entryPrice - tpRange * tpProximity
    if lowest3 <= nearTPLevel and close > nearTPLevel
        activeTrade := "NONE", tp1Hit := false, tp2Hit := false

// ═══════════════════════════════════════════════════════
// ML-ENHANCED SIGNALS
// ═══════════════════════════════════════════════════════
bool buyBase    = not isSideways and rsiBullCross and close > low[1]
bool sellBase   = not isSideways and rsiBearCross and close < high[1]
bool buySignal  = buyBase  and mlBullish and (not useKernel or kernelUp)
bool sellSignal = sellBase and mlBearish and (not useKernel or kernelDown)
bool doBuy  = buySignal  and activeTrade != "LONG"
bool doSell = sellSignal and activeTrade != "SHORT"

// ═══════════════════════════════════════════════════════
// TRADE ENTRY
// ═══════════════════════════════════════════════════════
if doBuy
    activeTrade := "LONG"
    entryPrice  := close
    tp1Price    := close + atr * atrMultTP1
    tp2Price    := close + atr * atrMultTP2
    tp3Price    := close + atr * atrMultTP3
    slPrice     := close - atr * atrMultSL
    trailSL     := close - atr * atrMultSL
    tp1Hit      := false
    tp2Hit      := false
    tradeConf   := math.round(mlBull * 100)
    ef1 := f1, ef2 := f2, ef3 := f3, ef4 := f4
    ef5 := f5, ef6 := f6, ef7 := f7, ef8 := f8
    label.new(bar_index, low, "🤖 BUY  ML:" + str.tostring(tradeConf) + "%\nEnt: " + str.tostring(entryPrice, "#.##") + "\nTP1: " + str.tostring(tp1Price, "#.##") + "\nTP2: " + str.tostring(tp2Price, "#.##") + "\nTP3: " + str.tostring(tp3Price, "#.##") + "\nSL:  " + str.tostring(slPrice, "#.##"), color=color.green, textcolor=color.white, style=label.style_label_up, size=size.small)

if doSell
    activeTrade := "SHORT"
    entryPrice  := close
    tp1Price    := close - atr * atrMultTP1
    tp2Price    := close - atr * atrMultTP2
    tp3Price    := close - atr * atrMultTP3
    slPrice     := close + atr * atrMultSL
    trailSL     := close + atr * atrMultSL
    tp1Hit      := false
    tp2Hit      := false
    tradeConf   := math.round(mlBear * 100)
    ef1 := f1, ef2 := f2, ef3 := f3, ef4 := f4
    ef5 := f5, ef6 := f6, ef7 := f7, ef8 := f8
    label.new(bar_index, high, "🤖 SELL  ML:" + str.tostring(tradeConf) + "%\nEnt: " + str.tostring(entryPrice, "#.##") + "\nTP1: " + str.tostring(tp1Price, "#.##") + "\nTP2: " + str.tostring(tp2Price, "#.##") + "\nTP3: " + str.tostring(tp3Price, "#.##") + "\nSL:  " + str.tostring(slPrice, "#.##"), color=color.red, textcolor=color.white, style=label.style_label_down, size=size.small)

// ═══════════════════════════════════════════════════════
// WIN RATE
// ═══════════════════════════════════════════════════════
int   totalTrades = totalWins + totalLosses
float winRate     = totalTrades > 0 ? float(totalWins) / float(totalTrades) * 100.0 : 0.0

// ═══════════════════════════════════════════════════════
// VISUALS
// ═══════════════════════════════════════════════════════
bgcolor(isSideways                   ? color.new(color.yellow, 90) : na, title="Ranging Zone")
bgcolor(mlBullish and not isSideways ? color.new(color.green,  96) : na, title="ML Bull Zone")
bgcolor(mlBearish and not isSideways ? color.new(color.red,    96) : na, title="ML Bear Zone")
plot(maLong,  color=color.new(color.green, 50), linewidth=1, title="EMA 200")
plot(maShort, color=color.new(#0d64ac,     50), linewidth=1, title="EMA 50")
plot(useKernel ? kernelEst : na, color=kernelUp ? color.new(color.teal, 10) : color.new(color.purple, 10), linewidth=2, title="Kernel Estimate")
plot(activeTrade != "NONE" and tp1Hit ? slPrice : na, color=color.orange, style=plot.style_stepline, linewidth=2, title="Trail Stop")

// ═══════════════════════════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════════════════════════
float wSum    = w1 + w2 + w3 + w4 + w5 + w6 + w7 + w8
float wMax    = math.max(w1, math.max(w2, math.max(w3, math.max(w4, math.max(w5, math.max(w6, math.max(w7, w8)))))))
string topFeat = w1 == wMax ? "F1·RSI" : w2 == wMax ? "F2·ADX" : w3 == wMax ? "F3·ATR" : w4 == wMax ? "F4·BB" : w5 == wMax ? "F5·MACD" : w6 == wMax ? "F6·WR" : w7 == wMax ? "F7·CMO" : "F8·EMA"
string tpStage    = not tp1Hit ? "Targeting TP1" : not tp2Hit ? "TP1✓→TP2" : "TP2✓→TP3🚀"
color  stageColor = not tp1Hit ? color.white : not tp2Hit ? color.lime : color.aqua

var table hub = table.new(position.bottom_left, 4, 15, bgcolor=color.rgb(15,15,15), border_color=color.gray, border_width=1)

if barstate.islast
    table.cell(hub, 0, 0, "MIGO SNIPER  [ML + ADAPTIVE + ☁️CLOUD]", text_color=color.white, bgcolor=color.rgb(65,14,58))
    table.merge_cells(hub, 0, 0, 3, 0)

    string mktState      = isSideways ? "⚠ RANGING" : mainTrend == "UPTREND" ? "▲ UPTREND" : "▼ DOWNTREND"
    color  mktStateColor = isSideways ? color.yellow : mainTrend == "UPTREND" ? color.green : color.red
    table.cell(hub, 0, 1, "MKT STATE", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 1, mktState,    text_color=mktStateColor)
    table.merge_cells(hub, 1, 1, 3, 1)

    table.cell(hub, 0, 2, "ML BULL 🐂", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 2, str.tostring(math.round(mlBull * 100)) + "%", text_color=mlBullish ? color.lime : color.white)
    table.cell(hub, 2, 2, "ML BEAR 🐻", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 2, str.tostring(math.round(mlBear * 100)) + "%", text_color=mlBearish ? color.red : color.white)

    string kernelStr   = not useKernel ? "OFF" : kernelUp ? "▲ Rising" : "▼ Falling"
    color  kernelColor = not useKernel ? color.gray : kernelUp ? color.teal : color.purple
    table.cell(hub, 0, 3, "KERNEL", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 3, kernelStr, text_color=kernelColor)
    table.cell(hub, 2, 3, "CONF",   text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 3, isSideways ? "-" : str.tostring(tradeConf) + "%", text_color=color.yellow)

    table.cell(hub, 0, 4, "SIGNAL", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 4, isSideways ? "BLOCKED" : activeTrade, text_color=isSideways ? color.yellow : activeTrade == "LONG" ? color.green : activeTrade == "SHORT" ? color.red : color.yellow)
    table.cell(hub, 2, 4, "STAGE",  text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 4, activeTrade != "NONE" ? tpStage : "-", text_color=stageColor)

    table.cell(hub, 0, 5, "ENTRY",    text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 5, activeTrade != "NONE" ? str.tostring(entryPrice, "#.##") : "WAIT", text_color=color.white)
    table.cell(hub, 2, 5, "TRAIL SL", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 5, activeTrade != "NONE" and tp1Hit ? str.tostring(slPrice, "#.##") : "-", text_color=color.orange)

    table.cell(hub, 0, 6, "TP1", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 6, activeTrade != "NONE" ? str.tostring(tp1Price, "#.##") : "-", text_color=tp1Hit ? color.lime : color.green)
    table.cell(hub, 2, 6, "SL",  text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 6, activeTrade != "NONE" ? str.tostring(slPrice, "#.##") : "-", text_color=color.red)

    table.cell(hub, 0, 7, "TP2",    text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 7, activeTrade != "NONE" ? str.tostring(tp2Price, "#.##") : "-", text_color=tp2Hit ? color.lime : color.green)
    table.cell(hub, 2, 7, "TP3 🚀", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 7, activeTrade != "NONE" ? str.tostring(tp3Price, "#.##") : "-", text_color=color.aqua)

    table.cell(hub, 0, 8, "WINS",   text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 8, str.tostring(totalWins),   text_color=color.lime)
    table.cell(hub, 2, 8, "LOSSES", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 8, str.tostring(totalLosses), text_color=color.red)

    color wrColor = winRate >= 60.0 ? color.lime : winRate >= 45.0 ? color.yellow : color.red
    table.cell(hub, 0, 9, "WIN RATE 📊", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 9, totalTrades > 0 ? str.tostring(math.round(winRate)) + "%" : "NO DATA", text_color=wrColor)
    table.cell(hub, 2, 9, "TOP FEAT", text_color=color.gray, text_size=size.small)
    table.cell(hub, 3, 9, topFeat,    text_color=color.yellow)

    string wBar = "W1:" + str.tostring(math.round(w1/wSum*100)) + " W2:" + str.tostring(math.round(w2/wSum*100)) + " W3:" + str.tostring(math.round(w3/wSum*100)) + " W4:" + str.tostring(math.round(w4/wSum*100)) + " W5:" + str.tostring(math.round(w5/wSum*100)) + " W6:" + str.tostring(math.round(w6/wSum*100)) + " W7:" + str.tostring(math.round(w7/wSum*100)) + " W8:" + str.tostring(math.round(w8/wSum*100))
    table.cell(hub, 0, 10, wBar, text_color=color.new(color.aqua, 20), text_size=size.tiny)
    table.merge_cells(hub, 0, 10, 3, 10)

    float  volRatio  = atr / atrSma
    string volStatus = volRatio > 1.5 ? "HIGH VOL" : volRatio < 0.7 ? "LOW VOL" : "STABLE"
    color  volColor  = volStatus == "HIGH VOL" ? color.red : volStatus == "LOW VOL" ? color.aqua : color.green
    table.cell(hub, 0, 11, "MKT IMPACT", text_color=color.gray, text_size=size.small)
    table.cell(hub, 1, 11, volStatus, text_color=volColor)
    table.merge_cells(hub, 1, 11, 3, 11)

    string adxInfo = "ADX:" + str.tostring(math.round(adxVal, 1)) + (adxFlat ? "✗" : "✓") + "  ATR:" + (atrCompressed ? "✗" : "✓") + "  EMA:" + (emaTooClose ? "✗" : "✓")
    table.cell(hub, 0, 12, adxInfo, text_color=color.new(color.gray, 30), text_size=size.small)
    table.merge_cells(hub, 0, 12, 3, 12)

    string mlInfo = "k=" + str.tostring(mlK) + "  lag=" + str.tostring(mlLag) + "  min=" + str.tostring(math.round(mlMinScore * 100)) + "%  lr=" + str.tostring(learnRate)
    table.cell(hub, 0, 13, mlInfo, text_color=color.new(color.gray, 40), text_size=size.tiny)
    table.merge_cells(hub, 0, 13, 3, 13)

    table.cell(hub, 0, 14, "☁️ CLOUD SYNC ACTIVE — outcomes sent to backend", text_color=color.new(color.aqua, 40), text_size=size.tiny)
    table.merge_cells(hub, 0, 14, 3, 14)
