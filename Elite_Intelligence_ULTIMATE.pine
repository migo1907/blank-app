// © Mohamed - Elite Intelligence Trading System ULTIMATE
// Built for IC Markets + TradingView - XAU/USD Intraday
// 100% FREE - Full Institutional-Grade System
// Features: FVG, Order Blocks, Volume Analysis, Sessions, Liquidity, Divergence, Structure, HTF Levels, Protection
// VERSION: Full Auto — only Weekly Intelligence + Calendar require manual updates

//@version=6
indicator("Elite Intelligence ULTIMATE - Full Auto",
     overlay=true,
     max_labels_count=500,
     max_lines_count=500,
     max_boxes_count=500)

// CE10246 guard — unconditional non-na output, invisible (100% transparent)
plot(close, "", color=color.new(color.white, 100), display=display.all)

// ═══════════════════════════════════════════════════════════════════════════════
// TIMEFRAME AUTO-DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

current_tf_minutes = timeframe.in_seconds() / 60

is_1m  = current_tf_minutes == 1
is_2m  = current_tf_minutes == 2
is_5m  = current_tf_minutes == 5
is_15m = current_tf_minutes == 15
is_30m = current_tf_minutes == 30
is_1h  = current_tf_minutes == 60
is_4h  = current_tf_minutes == 240
is_daily = timeframe.isdaily

tf_display = is_1m ? "1M" : is_2m ? "2M" : is_5m ? "5M" : is_15m ? "15M" :
             is_30m ? "30M" : is_1h ? "1H" : is_4h ? "4H" : is_daily ? "Daily" : "Custom"

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 1 — WEEKLY INTELLIGENCE  (update every Sunday, ~2 min)
// ═══════════════════════════════════════════════════════════════════════════════

regime_score = input.int(0, "Market Regime Score  (-10 Bear → +10 Bull)",
     minval=-10, maxval=10, step=1,
     group="📊 Weekly Intelligence — Update Sunday")

fed_stance = input.string("Neutral", "Fed Stance",
     options=["Dovish", "Neutral", "Hawkish"],
     group="📊 Weekly Intelligence — Update Sunday")

usd_trend = input.string("Neutral", "USD Trend",
     options=["Weak", "Neutral", "Strong"],
     group="📊 Weekly Intelligence — Update Sunday")

geopolitical_risk = input.string("Medium", "Geopolitical Risk",
     options=["Low", "Medium", "High"],
     group="📊 Weekly Intelligence — Update Sunday")

risk_sentiment = input.string("Neutral", "Risk Sentiment",
     options=["Risk-On", "Neutral", "Risk-Off"],
     group="📊 Weekly Intelligence — Update Sunday")

intelligence_confidence = input.int(75, "Confidence %",
     minval=0, maxval=100, step=5,
     group="📊 Weekly Intelligence — Update Sunday")

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION 2 — FOREX FACTORY CALENDAR  (update daily, ~3 min)
// ═══════════════════════════════════════════════════════════════════════════════

event_1_enabled = input.bool(false, "Event 1 Active?",
     group="📅 Forex Factory — Update Daily")
event_1_name = input.string("", "Event 1 Name",
     group="📅 Forex Factory — Update Daily")
event_1_time = input.time(timestamp("2026-01-01 00:00"), "Event 1 Time (UTC)",
     group="📅 Forex Factory — Update Daily")
event_1_impact = input.string("High", "Event 1 Impact",
     options=["Medium", "High"],
     group="📅 Forex Factory — Update Daily")

event_2_enabled = input.bool(false, "Event 2 Active?",
     group="📅 Forex Factory — Update Daily")
event_2_name = input.string("", "Event 2 Name",
     group="📅 Forex Factory — Update Daily")
event_2_time = input.time(timestamp("2026-01-01 00:00"), "Event 2 Time (UTC)",
     group="📅 Forex Factory — Update Daily")
event_2_impact = input.string("High", "Event 2 Impact",
     options=["Medium", "High"],
     group="📅 Forex Factory — Update Daily")

event_3_enabled = input.bool(false, "Event 3 Active?",
     group="📅 Forex Factory — Update Daily")
event_3_name = input.string("", "Event 3 Name",
     group="📅 Forex Factory — Update Daily")
event_3_time = input.time(timestamp("2026-01-01 00:00"), "Event 3 Time (UTC)",
     group="📅 Forex Factory — Update Daily")
event_3_impact = input.string("High", "Event 3 Impact",
     options=["Medium", "High"],
     group="📅 Forex Factory — Update Daily")

// ═══════════════════════════════════════════════════════════════════════════════
// ALL TECHNICAL PARAMETERS — FULLY AUTO-OPTIMISED PER TIMEFRAME
// No manual inputs needed below this line
// ═══════════════════════════════════════════════════════════════════════════════

// ── Indicator lengths ──────────────────────────────────────────────────────────
rsi_length = is_1m or is_2m ? 9 : 14
atr_length = is_1m or is_2m ? 10 : is_4h or is_daily ? 20 : 14
bb_length  = 20
bb_mult    = 2.0

ema_fast  = is_1m or is_2m ? 8  : is_4h ? 21 : 20
ema_slow  = is_1m or is_2m ? 21 : 50
ema_trend = is_1m or is_2m ? 50 : 200

// ── Smart Money ────────────────────────────────────────────────────────────────
fvg_max_display      = 3
ob_lookback          = is_1m or is_2m ? 10 : is_5m ? 20 : is_15m ? 30 : is_30m ? 40 : is_1h ? 50 : is_4h ? 100 : 50
ob_volume_threshold  = 1.5
max_order_blocks     = 2
fvg_score_weight     = 2.0
ob_score_weight      = 3.0

// ── Volume ─────────────────────────────────────────────────────────────────────
vwap_band_mult            = 2.0
volume_delta_period        = 14
relative_volume_threshold  = 2.0
volume_score_weight        = 2.0

// ── Sessions (UTC hours) ──────────────────────────────────────────────────────
asian_start          = 0
london_start         = 8
ny_start             = 13
london_kz_start      = 7
london_kz_end        = 10
ny_kz_start          = 13
ny_kz_end            = 16
dead_zone_start      = 21
dead_zone_end        = 1
killzone_boost       = 2.0
deadzone_penalty     = -3.0

// ── Liquidity ─────────────────────────────────────────────────────────────────
equal_level_tolerance   = 0.05
sweep_confirmation_bars = 3
liquidity_sweep_weight  = 3.0

// ── Divergence ────────────────────────────────────────────────────────────────
divergence_weight = 3.0

// ── Market structure ──────────────────────────────────────────────────────────
structure_lookback        = 10
with_structure_boost      = 2.0
counter_structure_penalty = -2.0

// ── News shock ────────────────────────────────────────────────────────────────
atr_shock_threshold    = 2.0
volume_shock_threshold = 3.0
velocity_extreme       = 0.30
velocity_high          = 0.15
velocity_moderate      = 0.08

shock_pause_extreme  = is_1m or is_2m ? 30 : is_5m ? 12 : is_15m ? 4 : is_30m ? 2 : 1
shock_pause_high     = is_1m or is_2m ? 15 : is_5m ? 6  : is_15m ? 2 : is_30m ? 1 : 1
shock_pause_moderate = is_1m or is_2m ? 10 : is_5m ? 3  : is_15m ? 1 : 1

// ── Signal thresholds ─────────────────────────────────────────────────────────
buy_threshold  = is_1m or is_2m ? 8 : is_5m ? 6 : is_15m ? 6 : is_30m ? 5 : is_1h ? 5 : is_4h ? 4 : 6
sell_threshold = is_1m or is_2m ? -8 : is_5m ? -6 : is_15m ? -6 : is_30m ? -5 : is_1h ? -5 : is_4h ? -4 : -6
min_risk_reward = 1.5

// ── TP / SL ATR multipliers ───────────────────────────────────────────────────
sl_atr_multiplier  = is_1m or is_2m ? 0.4 : is_5m ? 0.5 : is_15m ? 0.6 : is_30m ? 0.7 : is_1h ? 0.8 : is_4h ? 1.0 : 0.5
tp1_atr_multiplier = is_1m or is_2m ? 1.0 : is_5m ? 1.5 : is_15m ? 2.0 : is_30m ? 2.5 : is_1h ? 3.0 : is_4h ? 4.0 : 1.5
tp2_atr_multiplier = is_1m or is_2m ? 2.0 : is_5m ? 2.5 : is_15m ? 3.5 : is_30m ? 4.5 : is_1h ? 5.0 : is_4h ? 6.0 : 2.5

// ── Protection ────────────────────────────────────────────────────────────────
daily_loss_limit = 150.0

// ═══════════════════════════════════════════════════════════════════════════════
// CORE TECHNICAL INDICATORS
// ═══════════════════════════════════════════════════════════════════════════════

rsi   = ta.rsi(close, rsi_length)
atr   = ta.atr(atr_length)
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_length, bb_mult)
ema20  = ta.ema(close, ema_fast)
ema50  = ta.ema(close, ema_slow)
ema200 = ta.ema(close, ema_trend)

// Multi-timeframe RSI
rsi_1h    = request.security(syminfo.tickerid, "60",  ta.rsi(close, rsi_length), lookahead=barmerge.lookahead_off)
rsi_4h    = request.security(syminfo.tickerid, "240", ta.rsi(close, rsi_length), lookahead=barmerge.lookahead_off)
rsi_daily = request.security(syminfo.tickerid, "D",   ta.rsi(close, rsi_length), lookahead=barmerge.lookahead_off)

// Bollinger squeeze
bb_width   = (bb_upper - bb_lower) / bb_mid
bb_squeeze = bb_width < ta.sma(bb_width, 20) * 0.8

// Swing points
swing_high = ta.pivothigh(high, 5, 5)
swing_low  = ta.pivotlow(low,  5, 5)

var float last_swing_high = na
var float last_swing_low  = na
if not na(swing_high)
    last_swing_high := swing_high
if not na(swing_low)
    last_swing_low := swing_low

// MA alignment
ma_bullish_align = ema20 > ema50 and ema50 > ema200
ma_bearish_align = ema20 < ema50 and ema50 < ema200

// ═══════════════════════════════════════════════════════════════════════════════
// VWAP
// ═══════════════════════════════════════════════════════════════════════════════

vwap_value  = ta.vwap(close)
vwap_stddev = ta.stdev(close, 20)
vwap_upper  = vwap_value + vwap_stddev * vwap_band_mult
vwap_lower  = vwap_value - vwap_stddev * vwap_band_mult

plot(vwap_value,  "VWAP",       color=color.new(color.orange, 0),  linewidth=2)
plot(vwap_upper,  "VWAP Upper", color=color.new(color.orange, 70))
plot(vwap_lower,  "VWAP Lower", color=color.new(color.orange, 70))

// ═══════════════════════════════════════════════════════════════════════════════
// VOLUME ANALYSIS
// ═══════════════════════════════════════════════════════════════════════════════

normal_volume = ta.sma(volume, 20)
relative_volume = volume / normal_volume
high_volume = relative_volume > relative_volume_threshold

volume_delta  = close > open ? volume : close < open ? -volume : 0
cumulative_delta = ta.cum(volume_delta)
delta_sma     = ta.sma(cumulative_delta, volume_delta_period)
delta_bullish = cumulative_delta > delta_sma
delta_bearish = cumulative_delta < delta_sma

// ═══════════════════════════════════════════════════════════════════════════════
// FAIR VALUE GAPS (FVG)
// ═══════════════════════════════════════════════════════════════════════════════

bullish_fvg        = low > high[2]
bullish_fvg_top    = low
bullish_fvg_bottom = high[2]

bearish_fvg        = high < low[2]
bearish_fvg_top    = low[2]
bearish_fvg_bottom = high

var box[] bullish_fvg_boxes = array.new<box>()
var box[] bearish_fvg_boxes = array.new<box>()

if bullish_fvg
    if array.size(bullish_fvg_boxes) >= fvg_max_display
        box.delete(array.shift(bullish_fvg_boxes))
    array.push(bullish_fvg_boxes, box.new(bar_index, bullish_fvg_top, bar_index + 50, bullish_fvg_bottom,
         bgcolor=color.new(color.green, 85), border_color=color.new(color.green, 50), border_width=1))

if bearish_fvg
    if array.size(bearish_fvg_boxes) >= fvg_max_display
        box.delete(array.shift(bearish_fvg_boxes))
    array.push(bearish_fvg_boxes, box.new(bar_index, bearish_fvg_top, bar_index + 50, bearish_fvg_bottom,
         bgcolor=color.new(color.red, 85), border_color=color.new(color.red, 50), border_width=1))

var bool in_bullish_fvg = false
var bool in_bearish_fvg = false

for i = 0 to array.size(bullish_fvg_boxes) - 1
    b = array.get(bullish_fvg_boxes, i)
    if close >= box.get_bottom(b) and close <= box.get_top(b)
        in_bullish_fvg := true
        break

for i = 0 to array.size(bearish_fvg_boxes) - 1
    b = array.get(bearish_fvg_boxes, i)
    if close >= box.get_bottom(b) and close <= box.get_top(b)
        in_bearish_fvg := true
        break

// ═══════════════════════════════════════════════════════════════════════════════
// ORDER BLOCKS
// ═══════════════════════════════════════════════════════════════════════════════

var box[] bullish_ob_boxes = array.new<box>()
var box[] bearish_ob_boxes = array.new<box>()

bullish_ob_detected = false
bullish_ob_high     = 0.0
bullish_ob_low      = 0.0

for i = 1 to ob_lookback
    if close[i] < open[i] and volume[i] > normal_volume[i] * ob_volume_threshold
        if close > high[i] and (close - low[i]) > atr * 1.5
            bullish_ob_detected := true
            bullish_ob_high     := high[i]
            bullish_ob_low      := low[i]
            break

bearish_ob_detected = false
bearish_ob_high     = 0.0
bearish_ob_low      = 0.0

for i = 1 to ob_lookback
    if close[i] > open[i] and volume[i] > normal_volume[i] * ob_volume_threshold
        if close < low[i] and (high[i] - close) > atr * 1.5
            bearish_ob_detected := true
            bearish_ob_high     := high[i]
            bearish_ob_low      := low[i]
            break

if bullish_ob_detected
    if array.size(bullish_ob_boxes) >= max_order_blocks
        box.delete(array.shift(bullish_ob_boxes))
    array.push(bullish_ob_boxes, box.new(bar_index, bullish_ob_high, bar_index + 50, bullish_ob_low,
         bgcolor=color.new(color.blue, 80), border_color=color.new(color.blue, 30), border_width=2))

if bearish_ob_detected
    if array.size(bearish_ob_boxes) >= max_order_blocks
        box.delete(array.shift(bearish_ob_boxes))
    array.push(bearish_ob_boxes, box.new(bar_index, bearish_ob_high, bar_index + 50, bearish_ob_low,
         bgcolor=color.new(color.purple, 80), border_color=color.new(color.purple, 30), border_width=2))

var bool in_bullish_ob = false
var bool in_bearish_ob = false

for i = 0 to array.size(bullish_ob_boxes) - 1
    b = array.get(bullish_ob_boxes, i)
    if close >= box.get_bottom(b) and close <= box.get_top(b)
        in_bullish_ob := true
        break

for i = 0 to array.size(bearish_ob_boxes) - 1
    b = array.get(bearish_ob_boxes, i)
    if close >= box.get_bottom(b) and close <= box.get_top(b)
        in_bearish_ob := true
        break

// ═══════════════════════════════════════════════════════════════════════════════
// SESSIONS & KILL ZONES
// ═══════════════════════════════════════════════════════════════════════════════

current_hour = hour(time, "UTC")

in_london_killzone = current_hour >= london_kz_start and current_hour < london_kz_end
in_ny_killzone     = current_hour >= ny_kz_start     and current_hour < ny_kz_end
in_killzone        = in_london_killzone or in_ny_killzone
in_dead_zone       = current_hour >= dead_zone_start or current_hour <= dead_zone_end

// Session open markers
if current_hour == london_start
    line.new(bar_index, low, bar_index, high, color=color.new(color.yellow, 50), width=2)
    label.new(bar_index, high, "LONDON", style=label.style_label_down,
         color=color.new(color.yellow, 30), textcolor=color.white, size=size.small)

if current_hour == ny_start
    line.new(bar_index, low, bar_index, high, color=color.new(color.yellow, 50), width=2)
    label.new(bar_index, high, "NY", style=label.style_label_down,
         color=color.new(color.yellow, 30), textcolor=color.white, size=size.small)

bgcolor(in_killzone  ? color.new(color.green, 95) : na, title="Kill Zone")
bgcolor(in_dead_zone ? color.new(color.red,   95) : na, title="Dead Zone")

// ═══════════════════════════════════════════════════════════════════════════════
// LIQUIDITY — EQUAL HIGHS / LOWS & SWEEPS
// ═══════════════════════════════════════════════════════════════════════════════

var float[] recent_highs     = array.new<float>()
var int[]   recent_high_bars = array.new<int>()

if not na(swing_high)
    for i = 0 to array.size(recent_highs) - 1
        eh = array.get(recent_highs, i)
        if math.abs(swing_high - eh) / eh * 100 <= equal_level_tolerance
            eb = array.get(recent_high_bars, i)
            line.new(eb, eh, bar_index, swing_high,
                 color=color.new(color.red, 30), width=2, style=line.style_dashed)
            label.new(bar_index, swing_high, "EQH",
                 style=label.style_label_down, color=color.new(color.red, 20),
                 textcolor=color.white, size=size.tiny)
    array.push(recent_highs, swing_high)
    array.push(recent_high_bars, bar_index)
    if array.size(recent_highs) > 20
        array.shift(recent_highs)
        array.shift(recent_high_bars)

var float[] recent_lows     = array.new<float>()
var int[]   recent_low_bars = array.new<int>()

if not na(swing_low)
    for i = 0 to array.size(recent_lows) - 1
        el = array.get(recent_lows, i)
        if math.abs(swing_low - el) / el * 100 <= equal_level_tolerance
            eb = array.get(recent_low_bars, i)
            line.new(eb, el, bar_index, swing_low,
                 color=color.new(color.green, 30), width=2, style=line.style_dashed)
            label.new(bar_index, swing_low, "EQL",
                 style=label.style_label_up, color=color.new(color.green, 20),
                 textcolor=color.white, size=size.tiny)
    array.push(recent_lows, swing_low)
    array.push(recent_low_bars, bar_index)
    if array.size(recent_lows) > 20
        array.shift(recent_lows)
        array.shift(recent_low_bars)

var bool bullish_sweep_detected = false
var bool bearish_sweep_detected = false

for i = 0 to array.size(recent_lows) - 1
    liq_low = array.get(recent_lows, i)
    liq_bar = array.get(recent_low_bars, i)
    if low[1] < liq_low and close > open and close > close[1] and close > liq_low
        if bar_index - liq_bar <= sweep_confirmation_bars
            bullish_sweep_detected := true
            label.new(bar_index, low, "SWEEP↑", style=label.style_label_up,
                 color=color.new(color.lime, 0), textcolor=color.white, size=size.normal)
            break

for i = 0 to array.size(recent_highs) - 1
    liq_high = array.get(recent_highs, i)
    liq_bar  = array.get(recent_high_bars, i)
    if high[1] > liq_high and close < open and close < close[1] and close < liq_high
        if bar_index - liq_bar <= sweep_confirmation_bars
            bearish_sweep_detected := true
            label.new(bar_index, high, "SWEEP↓", style=label.style_label_down,
                 color=color.new(color.red, 0), textcolor=color.white, size=size.normal)
            break

// ═══════════════════════════════════════════════════════════════════════════════
// BREAK OF STRUCTURE (BOS)
// ═══════════════════════════════════════════════════════════════════════════════

bullish_bos = not na(last_swing_high) and close > last_swing_high and close[1] <= last_swing_high
bearish_bos = not na(last_swing_low)  and close < last_swing_low  and close[1] >= last_swing_low

if bullish_bos
    line.new(bar_index, last_swing_high, bar_index + 5, last_swing_high,
         color=color.new(color.green, 0), width=2)
    label.new(bar_index, last_swing_high, "BOS",
         style=label.style_label_up, color=color.new(color.green, 20),
         textcolor=color.white, size=size.small)

if bearish_bos
    line.new(bar_index, last_swing_low, bar_index + 5, last_swing_low,
         color=color.new(color.red, 0), width=2)
    label.new(bar_index, last_swing_low, "BOS",
         style=label.style_label_down, color=color.new(color.red, 20),
         textcolor=color.white, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// DIVERGENCE — pre-computed at global scope (CE10123 compliance)
// ═══════════════════════════════════════════════════════════════════════════════

div_low_price_cur   = ta.valuewhen(not na(swing_low),  low,  0)
div_low_price_prev  = ta.valuewhen(not na(swing_low),  low,  1)
div_rsi_at_low_cur  = ta.valuewhen(not na(swing_low),  rsi,  0)
div_rsi_at_low_prev = ta.valuewhen(not na(swing_low),  rsi,  1)

div_high_price_cur   = ta.valuewhen(not na(swing_high), high, 0)
div_high_price_prev  = ta.valuewhen(not na(swing_high), high, 1)
div_rsi_at_high_cur  = ta.valuewhen(not na(swing_high), rsi,  0)
div_rsi_at_high_prev = ta.valuewhen(not na(swing_high), rsi,  1)

var bool bullish_divergence = false
var bool bearish_divergence = false

if not na(swing_low)
    if div_low_price_cur < div_low_price_prev and div_rsi_at_low_cur > div_rsi_at_low_prev
        bullish_divergence := true
        label.new(bar_index, low, "DIV+", style=label.style_label_up,
             color=color.new(color.aqua, 20), textcolor=color.white, size=size.small)

if not na(swing_high)
    if div_high_price_cur > div_high_price_prev and div_rsi_at_high_cur < div_rsi_at_high_prev
        bearish_divergence := true
        label.new(bar_index, high, "DIV-", style=label.style_label_down,
             color=color.new(color.fuchsia, 20), textcolor=color.white, size=size.small)

// ═══════════════════════════════════════════════════════════════════════════════
// MARKET STRUCTURE
// ═══════════════════════════════════════════════════════════════════════════════

var string market_structure = "RANGING"
var bool   uptrend   = false
var bool   downtrend = false

var float[] structure_highs = array.new<float>()
var float[] structure_lows  = array.new<float>()

if not na(swing_high)
    array.push(structure_highs, swing_high)
    if array.size(structure_highs) > structure_lookback
        array.shift(structure_highs)

if not na(swing_low)
    array.push(structure_lows, swing_low)
    if array.size(structure_lows) > structure_lookback
        array.shift(structure_lows)

if array.size(structure_highs) >= 2 and array.size(structure_lows) >= 2
    hh = array.get(structure_highs, array.size(structure_highs)-1) > array.get(structure_highs, array.size(structure_highs)-2)
    hl = array.get(structure_lows,  array.size(structure_lows)-1)  > array.get(structure_lows,  array.size(structure_lows)-2)
    lh = array.get(structure_highs, array.size(structure_highs)-1) < array.get(structure_highs, array.size(structure_highs)-2)
    ll = array.get(structure_lows,  array.size(structure_lows)-1)  < array.get(structure_lows,  array.size(structure_lows)-2)

    if hh and hl
        market_structure := "UPTREND"
        uptrend   := true
        downtrend := false
    else if lh and ll
        market_structure := "DOWNTREND"
        uptrend   := false
        downtrend := true
    else
        market_structure := "RANGING"
        uptrend   := false
        downtrend := false

// ═══════════════════════════════════════════════════════════════════════════════
// HTF LEVELS
// ═══════════════════════════════════════════════════════════════════════════════

daily_high = request.security(syminfo.tickerid, "D",   high, lookahead=barmerge.lookahead_on)
daily_low  = request.security(syminfo.tickerid, "D",   low,  lookahead=barmerge.lookahead_on)
h4_high    = request.security(syminfo.tickerid, "240", high, lookahead=barmerge.lookahead_on)
h4_low     = request.security(syminfo.tickerid, "240", low,  lookahead=barmerge.lookahead_on)
h1_high    = request.security(syminfo.tickerid, "60",  high, lookahead=barmerge.lookahead_on)
h1_low     = request.security(syminfo.tickerid, "60",  low,  lookahead=barmerge.lookahead_on)

plot(daily_high, "Daily High", color=color.new(color.red,    30), linewidth=2)
plot(daily_low,  "Daily Low",  color=color.new(color.green,  30), linewidth=2)
plot(h4_high,    "4H High",    color=color.new(color.orange, 50), linewidth=1)
plot(h4_low,     "4H Low",     color=color.new(color.lime,   50), linewidth=1)
plot(h1_high,    "1H High",    color=color.new(color.yellow, 70), linewidth=1)
plot(h1_low,     "1H Low",     color=color.new(color.aqua,   70), linewidth=1)

// ═══════════════════════════════════════════════════════════════════════════════
// NEWS SHOCK DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

normal_atr  = ta.sma(atr, 20)
atr_ratio   = atr / normal_atr
volume_ratio = volume / normal_volume

price_change_5bars = math.abs(close - close[5]) / close * 100
velocity_per_minute = price_change_5bars / 5

atr_shock          = atr_ratio   > atr_shock_threshold
volume_shock       = volume_ratio > volume_shock_threshold
news_shock_detected = atr_shock and volume_shock

var string impact_level = "NORMAL"
if news_shock_detected
    impact_level := velocity_per_minute > velocity_extreme  ? "EXTREME"  :
                    velocity_per_minute > velocity_high     ? "HIGH"     :
                    velocity_per_minute > velocity_moderate ? "MODERATE" : "NORMAL"

var int bars_since_shock = 999
bars_since_shock := news_shock_detected ? 0 : bars_since_shock + 1

pause_duration = impact_level == "EXTREME"  ? shock_pause_extreme  :
                 impact_level == "HIGH"     ? shock_pause_high     :
                 impact_level == "MODERATE" ? shock_pause_moderate : 0

shock_pause_active = bars_since_shock < pause_duration

// ═══════════════════════════════════════════════════════════════════════════════
// FOREX FACTORY CALENDAR
// ═══════════════════════════════════════════════════════════════════════════════

f_in_event_window(enabled, evt_time, impact) =>
    if not enabled
        false
    else
        buf_before = impact == "High" ? 30 * 60000 : 15 * 60000
        buf_after  = impact == "High" ? 60 * 60000 : 30 * 60000
        time >= evt_time - buf_before and time <= evt_time + buf_after

in_event_1 = f_in_event_window(event_1_enabled, event_1_time, event_1_impact)
in_event_2 = f_in_event_window(event_2_enabled, event_2_time, event_2_impact)
in_event_3 = f_in_event_window(event_3_enabled, event_3_time, event_3_impact)

calendar_pause_active = in_event_1 or in_event_2 or in_event_3

var string next_event_name = ""
if event_1_enabled and time < event_1_time
    next_event_name := event_1_name
else if event_2_enabled and time < event_2_time
    next_event_name := event_2_name
else if event_3_enabled and time < event_3_time
    next_event_name := event_3_name

// ═══════════════════════════════════════════════════════════════════════════════
// FUNDAMENTAL SCORE
// ═══════════════════════════════════════════════════════════════════════════════

fed_score       = fed_stance       == "Dovish"   ?  2 : fed_stance       == "Hawkish" ? -2 : 0
usd_score       = usd_trend        == "Weak"     ?  2 : usd_trend        == "Strong"  ? -2 : 0
geo_score       = geopolitical_risk == "High"    ?  2 : geopolitical_risk == "Low"    ? -1 : 0
sentiment_score = risk_sentiment   == "Risk-Off"  ?  2 : risk_sentiment   == "Risk-On" ? -1 : 0

fundamental_score = regime_score + fed_score + usd_score + geo_score + sentiment_score

// ═══════════════════════════════════════════════════════════════════════════════
// TECHNICAL CONFLUENCE SCORE
// ═══════════════════════════════════════════════════════════════════════════════

technical_score = 0.0

// Multi-TF RSI
technical_score := technical_score + (rsi_4h < 25 ? 3 : rsi_4h < 30 ? 2 : rsi_4h > 75 ? -3 : rsi_4h > 70 ? -2 : 0)
technical_score := technical_score + (rsi_daily < 30 ? 2 : rsi_daily > 70 ? -2 : 0)
technical_score := technical_score + (rsi_1h < 35 ? 1 : rsi_1h > 65 ? -1 : 0)

// Bollinger position
bb_position = (close - bb_lower) / (bb_upper - bb_lower)
technical_score := technical_score + (bb_position < 0.2 ? 1.5 : bb_position > 0.8 ? -1.5 : 0)
technical_score := technical_score + (bb_squeeze ? 1.0 : 0.0)

// MA alignment
technical_score := technical_score + (ma_bullish_align ? 2 : ma_bearish_align ? -2 : 0)

// Price vs EMAs
above_all_emas = close > ema20 and close > ema50 and close > ema200
below_all_emas = close < ema20 and close < ema50 and close < ema200
technical_score := technical_score + (above_all_emas ? 1 : below_all_emas ? -1 : 0)

// VWAP
technical_score := technical_score + (close > vwap_value ? 0.5 : close < vwap_value ? -0.5 : 0)

// Volume
technical_score := technical_score + (high_volume and delta_bullish ? volume_score_weight :
                                      high_volume and delta_bearish ? -volume_score_weight : 0)

// Smart Money
technical_score := technical_score + (in_bullish_fvg ? fvg_score_weight : in_bearish_fvg ? -fvg_score_weight : 0)
technical_score := technical_score + (in_bullish_ob  ? ob_score_weight  : in_bearish_ob  ? -ob_score_weight  : 0)

// Liquidity sweeps
technical_score := technical_score + (bullish_sweep_detected ? liquidity_sweep_weight :
                                      bearish_sweep_detected ? -liquidity_sweep_weight : 0)

// Divergence
technical_score := technical_score + (bullish_divergence ? divergence_weight :
                                      bearish_divergence ? -divergence_weight : 0)

// Structure
technical_score := technical_score + (uptrend   and technical_score > 0 ?  with_structure_boost :
                                      downtrend  and technical_score < 0 ? -with_structure_boost :
                                      uptrend   and technical_score < 0 ?  counter_structure_penalty :
                                      downtrend  and technical_score > 0 ? -counter_structure_penalty : 0)

// Session
technical_score := technical_score + (in_killzone ? killzone_boost : in_dead_zone ? deadzone_penalty : 0)

// ═══════════════════════════════════════════════════════════════════════════════
// CONTEXT MULTIPLIER & FINAL SCORE
// ═══════════════════════════════════════════════════════════════════════════════

both_bullish = technical_score > 0 and fundamental_score > 0
both_bearish = technical_score < 0 and fundamental_score < 0
conflicting  = (technical_score > 0 and fundamental_score < 0) or
               (technical_score < 0 and fundamental_score > 0)

context_multiplier = both_bullish or both_bearish ? 1.5 : conflicting ? 0.6 : 1.0

if atr_ratio > 1.5
    context_multiplier := context_multiplier * 0.7
if bb_squeeze
    context_multiplier := context_multiplier * 1.2

confidence_factor = intelligence_confidence / 100.0
final_score = technical_score * context_multiplier * confidence_factor

signal_strength = math.abs(final_score) >= 8 ? "HIGH" :
                  math.abs(final_score) >= 6 ? "MEDIUM" : "LOW"

// ═══════════════════════════════════════════════════════════════════════════════
// DYNAMIC TP / SL
// ═══════════════════════════════════════════════════════════════════════════════

sl_long   = (na(last_swing_low)  ? close - atr * 2 : last_swing_low)  - atr * sl_atr_multiplier
sl_short  = (na(last_swing_high) ? close + atr * 2 : last_swing_high) + atr * sl_atr_multiplier
tp1_long  = close + atr * tp1_atr_multiplier
tp2_long  = close + atr * tp2_atr_multiplier
tp1_short = close - atr * tp1_atr_multiplier
tp2_short = close - atr * tp2_atr_multiplier
rr_long   = (tp1_long  - close) / (close - sl_long)
rr_short  = (close - tp1_short) / (sl_short - close)

// ═══════════════════════════════════════════════════════════════════════════════
// DRAWDOWN PROTECTION
// ═══════════════════════════════════════════════════════════════════════════════

var float daily_pnl   = 0.0
var int   current_day = dayofmonth(time)

if dayofmonth(time) != current_day
    daily_pnl   := 0.0
    current_day := dayofmonth(time)

daily_limit_hit = daily_pnl <= -daily_loss_limit

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNAL GENERATION
// ═══════════════════════════════════════════════════════════════════════════════

trading_paused = calendar_pause_active or shock_pause_active or in_dead_zone or daily_limit_hit

buy_signal  = final_score >= buy_threshold  and rr_long  >= min_risk_reward and not trading_paused
sell_signal = final_score <= sell_threshold and rr_short >= min_risk_reward and not trading_paused

// ═══════════════════════════════════════════════════════════════════════════════
// SIGNALS ON CHART
// ═══════════════════════════════════════════════════════════════════════════════

if buy_signal
    label.new(bar_index, low, "BUY\n" + signal_strength,
         style=label.style_label_up, color=color.new(color.green, 0),
         textcolor=color.white, size=size.normal)

if sell_signal
    label.new(bar_index, high, "SELL\n" + signal_strength,
         style=label.style_label_down, color=color.new(color.red, 0),
         textcolor=color.white, size=size.normal)

// ═══════════════════════════════════════════════════════════════════════════════
// TP / SL LINES
// ═══════════════════════════════════════════════════════════════════════════════

if buy_signal
    line.new(bar_index, sl_long,  bar_index + 10, sl_long,  color=color.red,   width=2, style=line.style_dashed)
    line.new(bar_index, tp1_long, bar_index + 10, tp1_long, color=color.green, width=2, style=line.style_solid)
    line.new(bar_index, tp2_long, bar_index + 10, tp2_long, color=color.green, width=1, style=line.style_dotted)

if sell_signal
    line.new(bar_index, sl_short,  bar_index + 10, sl_short,  color=color.red,   width=2, style=line.style_dashed)
    line.new(bar_index, tp1_short, bar_index + 10, tp1_short, color=color.green, width=2, style=line.style_solid)
    line.new(bar_index, tp2_short, bar_index + 10, tp2_short, color=color.green, width=1, style=line.style_dotted)

// ═══════════════════════════════════════════════════════════════════════════════
// DASHBOARD  — table locked to top-right corner
// ═══════════════════════════════════════════════════════════════════════════════

var table dashboard_tbl = na

if barstate.islast
    dt = ""
    dt := dt + "═══ ELITE INTELLIGENCE ULTIMATE ═══\n"
    dt := dt + "Timeframe : " + tf_display + "   (Auto-Optimised)\n\n"

    dt := dt + "📊 FUNDAMENTAL  (" + str.tostring(fundamental_score, "#.0") + ")\n"
    dt := dt + "Regime : " + (fundamental_score > 0 ? "BULLISH" : fundamental_score < 0 ? "BEARISH" : "NEUTRAL") + "\n"
    dt := dt + "Confidence : " + str.tostring(intelligence_confidence) + "%\n\n"

    dt := dt + "📈 TECHNICAL  (" + str.tostring(technical_score, "#.1") + ")\n"
    dt := dt + "4H RSI : " + str.tostring(rsi_4h, "#.1") +
         (rsi_4h < 25 ? "  EXTREME OS 🟢" : rsi_4h < 30 ? "  OS 🟡" :
          rsi_4h > 75 ? "  EXTREME OB 🔴" : rsi_4h > 70 ? "  OB 🟠" : "  ⚪") + "\n"
    dt := dt + "Structure : " + market_structure + "\n"
    dt := dt + (conflicting ? "⚠️  CONFLICT\n\n" : "✅  ALIGNED\n\n")

    dt := dt + "💎 SMART MONEY\n"
    dt := dt + (in_bullish_fvg ? "In Bullish FVG ✅\n" : in_bearish_fvg ? "In Bearish FVG ⚠️\n" : "No FVG\n")
    dt := dt + (in_bullish_ob  ? "In Bullish OB  ✅\n" : in_bearish_ob  ? "In Bearish OB  ⚠️\n" : "No OB\n")
    dt := dt + (bullish_sweep_detected ? "Bullish Sweep 🟢\n" : bearish_sweep_detected ? "Bearish Sweep 🔴\n" : "")
    dt := dt + (bullish_divergence ? "Bullish Div ✅\n" : bearish_divergence ? "Bearish Div ⚠️\n" : "")
    dt := dt + "\n"

    dt := dt + "🕐 SESSION\n"
    dt := dt + (in_london_killzone ? "London Kill Zone 🎯\n" :
                in_ny_killzone     ? "NY Kill Zone 🎯\n"     :
                in_dead_zone       ? "DEAD ZONE 🛑\n"        : "Normal Hours\n")
    dt := dt + "\n"

    dt := dt + "📅 CALENDAR\n"
    if next_event_name != ""
        dt := dt + "Next : " + next_event_name + "\n"
    dt := dt + (calendar_pause_active ? "PRE-EVENT 🛑\n\n" : "Clear ✅\n\n")

    dt := dt + "⚡ VOLATILITY\n"
    dt := dt + "Impact : " + impact_level +
         (impact_level == "EXTREME" ? " 🔴" : impact_level == "HIGH" ? " 🟠" :
          impact_level == "MODERATE" ? " 🟡" : " ✅") + "\n"
    dt := dt + (shock_pause_active ? "Shock Pause : " + str.tostring(pause_duration - bars_since_shock) + " bars\n\n" : "\n")

    dt := dt + "🛡️ PROTECTION\n"
    dt := dt + (daily_limit_hit ? "⛔  DAILY LIMIT HIT\n\n" : "Active ✅\n\n")

    dt := dt + "🎯 SIGNAL  (" + str.tostring(final_score, "#.1") + ")\n"
    dt := dt + "Strength : " + signal_strength + "\n"

    if trading_paused
        pause_reason = calendar_pause_active ? "PRE-EVENT" :
                       shock_pause_active    ? "NEWS SHOCK" :
                       in_dead_zone          ? "DEAD ZONE"  :
                       daily_limit_hit       ? "DAILY LIMIT" : "PAUSED"
        dt := dt + "Status : PAUSED 🛑\n"
        dt := dt + "Reason : " + pause_reason + "\n"
    else if buy_signal
        dt := dt + "🟢 BUY SIGNAL\n"
        dt := dt + "Entry : " + str.tostring(close,    "#.2") + "\n"
        dt := dt + "SL    : " + str.tostring(sl_long,  "#.2") + "\n"
        dt := dt + "TP1   : " + str.tostring(tp1_long, "#.2") + "\n"
        dt := dt + "R:R   : " + str.tostring(rr_long,  "#.1") + ":1\n"
    else if sell_signal
        dt := dt + "🔴 SELL SIGNAL\n"
        dt := dt + "Entry : " + str.tostring(close,     "#.2") + "\n"
        dt := dt + "SL    : " + str.tostring(sl_short,  "#.2") + "\n"
        dt := dt + "TP1   : " + str.tostring(tp1_short, "#.2") + "\n"
        dt := dt + "R:R   : " + str.tostring(rr_short,  "#.1") + ":1\n"
    else
        dt := dt + "⚪  NO SIGNAL\n"

    dash_color = buy_signal  ? color.new(color.green,  10) :
                 sell_signal ? color.new(color.red,    10) :
                 trading_paused ? color.new(color.orange, 10) :
                 color.new(color.gray, 10)

    if na(dashboard_tbl)
        dashboard_tbl := table.new(position.top_right, 1, 1,
             border_width=1, border_color=color.gray,
             frame_width=1,  frame_color=color.gray)

    table.cell(dashboard_tbl, 0, 0, dt,
         text_color=color.white,
         text_size=size.small,
         bgcolor=dash_color,
         text_halign=text.align_left)

// ═══════════════════════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════════════════════

alertcondition(buy_signal,             "Buy Signal",        "BUY signal fired — check dashboard")
alertcondition(sell_signal,            "Sell Signal",       "SELL signal fired — check dashboard")
alertcondition(news_shock_detected,    "News Shock",        "NEWS SHOCK detected — check dashboard")
alertcondition(bullish_sweep_detected, "Bullish Sweep",     "LIQUIDITY SWEEP — bullish reversal likely")
alertcondition(bearish_sweep_detected, "Bearish Sweep",     "LIQUIDITY SWEEP — bearish reversal likely")
alertcondition(bullish_divergence,     "Bullish Divergence","BULLISH DIVERGENCE — reversal signal")
alertcondition(bearish_divergence,     "Bearish Divergence","BEARISH DIVERGENCE — reversal signal")
alertcondition(daily_limit_hit,        "Daily Limit Hit",   "DAILY LOSS LIMIT REACHED — stop trading")

plot(final_score, "Signal Score", color=color.new(color.gray, 100))
